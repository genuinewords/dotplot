---
import BaseLayout from "@theme/layouts/BaseLayout.astro";
import AdvancedDotPlotTool from "@theme/components/AdvancedDotPlotTool.astro";
import HowItWorks from "@theme/components/HowItWorks.astro";
import ChartSection from "@theme/components/ChartSection.astro";
import FAQ from "@theme/components/FAQ.astro";
import InteractiveIllustrations from "@theme/components/InteractiveIllustrations.astro";
import HomepageSchema from "@theme/components/HomepageSchema.astro";
import { defaultLocale } from "@src/i18n/config";
import { t } from "@src/i18n/utils";

const locale = defaultLocale;
---

<BaseLayout locale={locale} title={t(locale, "home.title")} description={t(locale, "home.description")}>
  <HomepageSchema locale={locale} slot="head" />

  <div class="page-content">
    <!-- Hero -->
    <div class="hero animate-fade-in-up" style="opacity: 0;">
      <span class="badge">{t(locale, "home.badge")}</span>
      <h1 class="hero-title">{t(locale, "home.h1")}</h1>
    </div>

    <!-- Advanced Dot Plot Tool Component -->
    <AdvancedDotPlotTool locale={locale} />

    <InteractiveIllustrations />

    <!-- What is a Dot Plot Maker®? -->
    <section class="educational-section section" style="margin-top: 4rem;">
      <div class="educational-container">
        <h2 class="section-title edu-title">What is a Dot Plot Maker®?</h2>
        <p class="educational-intro" style="text-align: center; max-width: 600px; margin: 0 auto 2.5rem; color: var(--color-text-secondary); font-size: 1.1rem; line-height: 1.6;">
          Dot Plot Maker® provides a professional, highly customizable interactive environment for instantly visualizing your datasets in just a few clicks.
        </p>
        <ul class="educational-list">
          <li>
            <span class="edu-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
            </span>
            <div>
              <strong>Instant Data Input:</strong> Manually enter data points seamlessly or instantly paste structured spreadsheet data directly into the tool for immediate rendering.
            </div>
          </li>
          <li>
            <span class="edu-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
            </span>
            <div>
              <strong>Complete Style Control:</strong> Dynamically adjust dot sizes, customize tool opacities, toggle structural grid lines, and precisely map your base primary color hexes.
            </div>
          </li>
          <li>
            <span class="edu-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16c0 1.1.9 2 2 2h12a2 2 0 0 0 2-2V8l-6-6z"></path><path d="M14 3v5h5M16 13H8M16 17H8M10 9H8"></path></svg>
            </span>
            <div>
              <strong>Live Data Table & Statistics:</strong> Automatically calculated descriptive statistics (Mean, Median, Standard Deviation) alongside a built-in frequency parsing matrix.
            </div>
          </li>
          <li>
            <span class="edu-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
            </span>
            <div>
              <strong>High-Quality Exports:</strong> Seamlessly download your generated visual as a crystal-clear scalable vector (SVG) or crisp high-resolution image format (PNG) for immediate publication.
            </div>
          </li>
        </ul>
      </div>
    </section>

    <!-- How It Works -->
    <HowItWorks locale={locale} />

    <!-- Chart Info Section -->
    <ChartSection locale={locale} />

    <!-- Feature Grid -->
    <section class="feature-grid-section animate-fade-in-up" style="opacity: 0; animation-delay: 0.3s; margin-top: 1rem;">
      <div style="text-align: center; margin-bottom: 2.5rem;">
        <h2 class="section-title">Why our Dot Plot Maker®?</h2>
      </div>
      <div class="feature-grid-container">
        <div class="feature-card">
          <div class="feature-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
          </div>
          <h3>Easy</h3>
          <p>Dot Plot Maker® makes it incredibly easy to build a dot plot in seconds.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
          </div>
          <h3>Copy & Paste</h3>
          <p>Instantly copy and paste your raw data directly into the Dot Plot Maker® spreadsheet.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
          </div>
          <h3>Online</h3>
          <p>Dot Plot Maker® is the sharpest way to build beautiful data visualizations completely online.</p>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <FAQ locale={locale} />
    
    <!-- Final CTA -->
    <!-- Final CTA -->
    <div class="final-cta">
      <h2>Dot Plot Maker® - No email required.</h2>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; margin-top: 2rem;">
        <a href="#pro-dot-plot-tool" class="btn-primary cta-btn"><span>Build Your Dot Plot</span></a>
        <a href="/professional-dot-plot-tool/" class="btn-secondary cta-btn" style="background: transparent; border: 1px solid var(--color-border); color: var(--color-text-primary);"><span>Try Dot Plot Pro</span></a>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: 3rem 0 2rem;
  }
  .hero-title {
    font-size: 3rem;
    font-weight: 900;
    line-height: 1.1;
    margin: 1rem 0;
    background: linear-gradient(135deg, var(--color-text-primary) 30%, var(--color-primary) 70%, var(--color-accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }
  .hero-intro {
    font-size: 1.15rem;
    color: var(--color-text-secondary);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.7;
  }
  @media (max-width: 768px) {
    .hero-title {
      font-size: 2rem;
    }
    .hero-intro {
      font-size: 1rem;
    }
    .feature-grid-container {
      grid-template-columns: 1fr;
      padding: 0 1rem;
    }
    .final-cta {
      padding: 3rem 1rem;
    }
    .final-cta h2 {
      font-size: 1.5rem;
    }
  }

  .final-cta {
    text-align: center;
    padding: 6rem 1rem 4rem;
    margin-top: 2rem;
    background: linear-gradient(180deg, rgba(255,255,255,0) 0%, rgba(0, 212, 170, 0.08) 100%);
    border-top: 1px solid var(--color-border);
  }
  .final-cta h2 {
    font-size: 2.2rem;
    font-weight: 800;
    max-width: 800px;
    margin: 0 auto 2rem;
    line-height: 1.3;
    color: var(--color-text-primary);
  }
  .cta-btn {
    display: inline-block;
    padding: 1rem 2.5rem;
    font-size: 1.1rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 8px;
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
    color: #ffffff;
    transition: all 0.2s ease;
    box-shadow: 0 8px 24px rgba(0, 212, 170, 0.22);
  }
  .cta-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(139, 92, 246, 0.22);
    background: linear-gradient(135deg, var(--color-accent), var(--color-primary));
    color: #ffffff !important;
  }

  .feature-grid-section {
    max-width: 1200px;
    margin: 0 auto 5rem;
    padding: 0 1rem;
  }
  .feature-grid-container {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  .feature-card {
    background: var(--color-bg-card, #ffffff);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 2rem;
    text-align: center;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .feature-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0, 212, 170, 0.12);
    border-color: rgba(0, 212, 170, 0.3);
  }
  .feature-icon {
    width: 48px;
    height: 48px;
    margin: 0 auto 1.25rem;
    background: rgba(0, 212, 170, 0.12);
    color: var(--color-primary);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .feature-card h3 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--color-text-primary);
  }
  .feature-card p {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .educational-section {
    padding: 2rem 1rem 5rem;
  }
  .educational-container {
    max-width: 860px;
    margin: 0 auto;
    background: var(--color-bg-card, #ffffff);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 3rem 2.5rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
  }
  .edu-title {
    text-align: center;
  }
  .educational-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }
  .educational-list li {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    font-size: 1.05rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }
  .edu-icon {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    border: 1px solid rgba(0, 212, 170, 0.3);
    background: rgba(0, 212, 170, 0.12);
    color: var(--color-primary);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .educational-list strong {
    color: var(--color-text-primary);
    display: block;
    margin-bottom: 0.2rem;
    font-size: 1.1rem;
  }
</style>

