---
import BaseLayout from "@theme/layouts/BaseLayout.astro";
import { defaultLocale, locales, localeNames } from "@src/i18n/config";
import { t, getLocaleHomeUrl } from "@src/i18n/utils";
import { getCollection } from "astro:content";
import siteConfig from "@src/config/site.json";

const locale = defaultLocale;

// Static pages (excluding dynamic routes and 404)
const staticPages = [
  { label: t(locale, "nav.home"), href: "/" },
  { label: t(locale, "nav.pro"), href: "/professional-dot-plot-tool/" },
  { label: t(locale, "nav.about"), href: "/about-us/" },
  { label: t(locale, "nav.contact"), href: "/contact-us/" },
  { label: t(locale, "nav.terms"), href: "/terms/" },
  { label: t(locale, "nav.privacy"), href: "/privacy/" },
  { label: t(locale, "nav.sitemap"), href: "/sitemap/" },
  { label: t(locale, "nav.blog"), href: "/blog/" },
];

// Locale homes
const localeLinks = locales.map((loc) => ({
  label: localeNames[loc],
  href: getLocaleHomeUrl(loc),
}));

// Localized professional tool pages
const localeProLinks = locales
  .filter((l) => l !== defaultLocale)
  .map((loc) => ({
    label: localeNames[loc],
    href: `/${loc}/professional-dot-plot-tool/`,
  }));

// Blog posts
let blogLinks: { label: string; href: string }[] = [];
try {
  const posts = await getCollection("blog");
  blogLinks = posts.map((post) => ({
    label: post.data.title,
    href: `/blog/${post.id}/`,
  }));
} catch {
  // No blog posts yet
}
---

<BaseLayout locale={locale} title={t(locale, "nav.sitemap")} description="Sitemap for Dot Plot Maker®">
  <div class="page-content">
    <div class="page-header animate-fade-in-up" style="opacity: 0;">
      <h1>{t(locale, "nav.sitemap")}</h1>
    </div>

    <div class="sitemap-content">
      <!-- Static Pages -->
      <section class="sitemap-section">
        <h2>Pages</h2>
        <ul class="sitemap-list">
          {staticPages.map((page) => (
            <li><a href={page.href}>{page.label}</a></li>
          ))}
        </ul>
      </section>

      <!-- Locale Homes -->
      <section class="sitemap-section">
        <h2>{t(locale, "common.switchLanguage")}</h2>
        <ul class="sitemap-list sitemap-grid">
          {localeLinks.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </section>

      <!-- Localized Professional Tool Pages -->
      {localeProLinks.length > 0 && (
        <section class="sitemap-section">
          <h2>{t(locale, "nav.pro")} — {t(locale, "common.switchLanguage")}</h2>
          <ul class="sitemap-list sitemap-grid">
            {localeProLinks.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </section>
      )}

      <!-- Blog Posts -->
      {blogLinks.length > 0 && (
        <section class="sitemap-section">
          <h2>{t(locale, "common.blogTitle")}</h2>
          <ul class="sitemap-list">
            {blogLinks.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </section>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .sitemap-content {
    max-width: 800px;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }
  .sitemap-section h2 {
    font-size: 1.3rem;
    margin-bottom: 1rem;
    color: var(--color-primary);
  }
  .sitemap-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .sitemap-list a {
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 0.2s;
  }
  .sitemap-list a:hover {
    color: var(--color-primary);
  }
  .sitemap-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 0.5rem;
  }
</style>
