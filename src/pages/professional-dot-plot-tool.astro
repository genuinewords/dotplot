---
import BaseLayout from "@theme/layouts/BaseLayout.astro";
import ProDotPlotTool from "@theme/components/ProDotPlotTool.astro";
import ProFAQ from "@theme/components/ProFAQ.astro";
import InteractiveIllustrations from "@theme/components/InteractiveIllustrations.astro";
import { t } from "@src/i18n/utils";
import { type Locale } from "@src/i18n/config";

const locale = "en" as Locale;
---
<BaseLayout locale={locale} title={t(locale, "pro.title")} description={t(locale, "pro.description")}>
  <Fragment slot="head">
    <meta name="keywords" content="professional dot plot maker, BI-grade dot plot maker, dot plot maker high-resolution export, dot plot maker for IEEE standards, dot plot maker with Excel upload, csv excel import dot plot, svg vector export dot plot" />
  </Fragment>

  <div class="page-content" style="padding: 2rem 1rem; max-width: 1200px; margin: 0 auto; min-height: 80vh;">
    
    <header style="text-align: center; margin-bottom: 2.5rem; margin-top: 2rem;">
      <span class="badge" style="margin-bottom: 1.25rem;">Professional Edition</span>
      <h1 class="section-title" style="font-size: 3.5rem; margin-bottom: 1rem; font-weight: 800; background: linear-gradient(135deg, var(--color-text-primary), var(--color-primary)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
        Advanced Dot Plot Tool for Professionals
      </h1>
      <p style="color: var(--color-text-secondary); max-width: 800px; margin: 0 auto; font-size: 1.25rem; line-height: 1.6;">
        The professional BI-grade dot plot maker engineered for precision data publication. Import CSV & Excel spreadsheets, export high-resolution SVG vectors, and dynamically configure every visual detail for IEEE-standard charts.
      </p>
    </header>

    <!-- Embedded Pro Tool -->
    <div style="background: var(--color-bg-card); border: 1px solid var(--color-border); border-radius: 16px; overflow: hidden; margin-bottom: 4rem; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25);">
      <ProDotPlotTool locale={locale} />
    </div>
    
    <!-- ══════════════════════════════════════════════════════ -->
    <!-- SECTION 1: CSV & Excel Import                        -->
    <!-- ══════════════════════════════════════════════════════ -->
    <section class="pro-feature-section" id="csv-excel-import">
      <div class="pro-feature-inner">
        <div class="pro-feature-icon-wrap">
          <div class="pro-feature-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
              <polyline points="14 2 14 8 20 8"></polyline>
              <line x1="16" y1="13" x2="8" y2="13"></line>
              <line x1="16" y1="17" x2="8" y2="17"></line>
              <polyline points="10 9 9 9 8 9"></polyline>
            </svg>
          </div>
          <span class="pro-feature-badge">Data Import</span>
        </div>
        <div class="pro-feature-content">
          <h2 class="pro-feature-heading">CSV & Excel File Import</h2>
          <p class="pro-feature-description">
            The <strong>dot plot maker with Excel upload</strong> capability handles complex multivariate datasets effortlessly. Drag and drop <code>.csv</code> or <code>.xlsx</code> files directly into the editor—the built-in SheetJS parser accurately maps every column and row, preserving your data structure for instant chart rendering.
          </p>
          <ul class="pro-feature-benefits">
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span>Direct <strong>.CSV and .XLSX parsing</strong> using the SheetJS engine for flawless data fidelity</span>
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span>Copy-paste from <strong>Microsoft Excel</strong> or <strong>Google Sheets</strong>—auto-detected instantly</span>
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span>Handles <strong>massive multivariate datasets</strong> with zero performance lag or page freezes</span>
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span><strong>100% client-side processing</strong>—your proprietary data never leaves your browser</span>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════ -->
    <!-- SECTION 2: SVG Vector Export                          -->
    <!-- ══════════════════════════════════════════════════════ -->
    <section class="pro-feature-section" id="svg-vector-export">
      <div class="pro-feature-inner reverse">
        <div class="pro-feature-icon-wrap">
          <div class="pro-feature-icon accent">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
              <circle cx="8.5" cy="8.5" r="1.5"></circle>
              <polyline points="21 15 16 10 5 21"></polyline>
            </svg>
          </div>
          <span class="pro-feature-badge accent">Vector Export</span>
        </div>
        <div class="pro-feature-content">
          <h2 class="pro-feature-heading">SVG Vector & High-Resolution Export</h2>
          <p class="pro-feature-description">
            Stop submitting blurry PNG charts to journals. Our <strong>dot plot maker high-resolution export</strong> generates infinitely scalable SVG vector graphics, providing publication-grade output for the <strong>dot plot maker for IEEE standards</strong> and every other academic or corporate format.
          </p>
          <ul class="pro-feature-benefits">
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span><strong>Direct-to-SVG vector output</strong> with crisp edges at any display resolution</span>
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span><strong>2x pixel-ratio PNG</strong> for crystal-clear raster exports when needed</span>
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span>Designed for <strong>IEEE, APA, and academic publishing pipelines</strong></span>
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span>Import directly into <strong>Figma, Illustrator, or InDesign</strong> for further design work</span>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════ -->
    <!-- SECTION 3: Dynamic Configuration                     -->
    <!-- ══════════════════════════════════════════════════════ -->
    <section class="pro-feature-section" id="dynamic-configuration">
      <div class="pro-feature-inner">
        <div class="pro-feature-icon-wrap">
          <div class="pro-feature-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="12" r="3"></circle>
              <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
            </svg>
          </div>
          <span class="pro-feature-badge">Configuration</span>
        </div>
        <div class="pro-feature-content">
          <h2 class="pro-feature-heading">Dynamic Configuration & Styling</h2>
          <p class="pro-feature-description">
            As a <strong>professional dot plot maker</strong>, every visual parameter is exposed for granular control. Toggle axes, resize data marks, switch data orientations, and apply corporate brand palettes—all in real-time with zero page reloads.
          </p>
          <ul class="pro-feature-benefits">
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span><strong>Binding, Formatting & Styling tabs</strong> for organized, granular control</span>
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span><strong>Row vs Column data modes</strong> supporting both long and wide dataset formats</span>
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span><strong>Toggle visibility</strong> of legends, grid lines, data labels, and axes individually</span>
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span><strong>Multi-panel layout modes</strong>—view data, styles, or preview in isolation</span>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════ -->
    <!-- Keyword Benefits Grid                                -->
    <!-- ══════════════════════════════════════════════════════ -->
    <section class="pro-keywords-section" id="pro-benefits">
      <h2 class="section-title" style="text-align: center; font-size: 2.5rem; margin-bottom: 0.5rem;">Why Professionals Choose Dot Plot Maker Pro</h2>
      <p style="text-align: center; color: var(--color-text-secondary); max-width: 700px; margin: 0 auto 3.5rem; font-size: 1.1rem;">A BI-grade dot plot maker built for researchers, analysts, and data teams who demand publication-quality output.</p>
      
      <div class="pro-keywords-grid">
        <div class="pro-keyword-card">
          <div class="keyword-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 20V10M18 20V4M6 20v-4"></path></svg>
          </div>
          <h3>Professional Dot Plot Maker</h3>
          <p>Enterprise-grade charting engine with precise data binding, multi-series support, and Cleveland dot plot range indicators.</p>
        </div>
        <div class="pro-keyword-card">
          <div class="keyword-icon accent">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path></svg>
          </div>
          <h3>BI-Grade Dot Plot Maker</h3>
          <p>Business intelligence-level visualization with multi-panel layouts, dynamic column mapping, and real-time data reactivity.</p>
        </div>
        <div class="pro-keyword-card">
          <div class="keyword-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
          </div>
          <h3>High-Resolution Export</h3>
          <p>2x pixel-ratio PNG and direct SVG vector exports ensure your dot plots look razor-sharp in every medium—print, web, or PDF.</p>
        </div>
        <div class="pro-keyword-card">
          <div class="keyword-icon accent">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
          </div>
          <h3>IEEE Standards Ready</h3>
          <p>Publication-grade SVG outputs compatible with IEEE, APA, and major academic journal formatting requirements out of the box.</p>
        </div>
        <div class="pro-keyword-card">
          <div class="keyword-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line></svg>
          </div>
          <h3>Excel Upload Support</h3>
          <p>Native .XLSX and .CSV file parsing powered by SheetJS—upload entire workbooks and visualize complex datasets in seconds.</p>
        </div>
        <div class="pro-keyword-card">
          <div class="keyword-icon accent">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
          </div>
          <h3>100% Client-Side Privacy</h3>
          <p>Zero data uploads. Your proprietary spreadsheets are processed entirely in your browser sandbox—guaranteed secure by design.</p>
        </div>
      </div>
    </section>

    <!-- Additional Interactive Visualizations -->
    <InteractiveIllustrations />

    <!-- FAQ -->
    <ProFAQ locale={locale} />

    <!-- Reciprocal Link SEO Block -->
    <div class="final-cta" style="text-align: center; margin-top: 4rem; margin-bottom: 2rem; padding: 3rem;">
      <h2 style="margin-bottom: 1.5rem; font-size: 2rem;">Prefer a simpler, faster tool?</h2>
      <p style="color: var(--color-text-secondary); max-width: 600px; margin: 0 auto 2rem; font-size: 1.1rem;">
        Sometimes you don't need a heavy duty spreadsheet loader. If you want to instantly paste simple arrays and download quick graphics, use our free basic version!
      </p>
      <a href="/" class="btn-primary cta-btn" style="padding: 1rem 2rem; font-size: 1.1rem;"><span>Try Basic Dot Plot Maker®</span></a>
    </div>

  </div>
</BaseLayout>

<style>
  /* ── Pro Feature Sections ── */
  .pro-feature-section {
    margin-bottom: 4rem;
    padding: 0;
  }
  .pro-feature-inner {
    display: flex;
    gap: 3rem;
    align-items: flex-start;
    padding: 3rem;
    border: 1px solid var(--color-border);
    border-radius: 16px;
    background: linear-gradient(135deg, rgba(0, 212, 170, 0.03), rgba(139, 92, 246, 0.03));
    transition: all 0.3s ease;
  }
  .pro-feature-inner:hover {
    border-color: var(--color-border-hover);
    box-shadow: 0 8px 32px rgba(0, 212, 170, 0.06);
    transform: translateY(-2px);
  }
  .pro-feature-inner.reverse {
    flex-direction: row-reverse;
    background: linear-gradient(135deg, rgba(139, 92, 246, 0.03), rgba(0, 212, 170, 0.03));
  }
  .pro-feature-inner.reverse:hover {
    box-shadow: 0 8px 32px rgba(139, 92, 246, 0.06);
  }

  .pro-feature-icon-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
    padding-top: 0.25rem;
  }
  .pro-feature-icon {
    width: 64px;
    height: 64px;
    border-radius: 16px;
    background: rgba(0, 212, 170, 0.12);
    border: 1px solid rgba(0, 212, 170, 0.2);
    color: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }
  .pro-feature-icon.accent {
    background: rgba(139, 92, 246, 0.12);
    border-color: rgba(139, 92, 246, 0.2);
    color: var(--color-accent);
  }
  .pro-feature-inner:hover .pro-feature-icon {
    transform: scale(1.05);
    box-shadow: 0 4px 16px rgba(0, 212, 170, 0.15);
  }
  .pro-feature-inner.reverse:hover .pro-feature-icon {
    box-shadow: 0 4px 16px rgba(139, 92, 246, 0.15);
  }
  .pro-feature-badge {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary);
    padding: 0.25rem 0.75rem;
    background: rgba(0, 212, 170, 0.1);
    border-radius: 999px;
    border: 1px solid rgba(0, 212, 170, 0.15);
  }
  .pro-feature-badge.accent {
    color: var(--color-accent);
    background: rgba(139, 92, 246, 0.1);
    border-color: rgba(139, 92, 246, 0.15);
  }

  .pro-feature-content {
    flex: 1;
  }
  .pro-feature-heading {
    font-size: 1.8rem;
    font-weight: 800;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, var(--color-text-primary), var(--color-primary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .pro-feature-description {
    color: var(--color-text-secondary);
    font-size: 1.05rem;
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }
  .pro-feature-description code {
    font-family: var(--font-mono);
    background: rgba(0, 212, 170, 0.1);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.9em;
    color: var(--color-primary);
  }
  .pro-feature-description strong {
    color: var(--color-text-primary);
  }

  .pro-feature-benefits {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .pro-feature-benefits li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }
  .pro-feature-benefits li svg {
    flex-shrink: 0;
    margin-top: 3px;
  }
  .pro-feature-benefits li strong {
    color: var(--color-text-primary);
  }

  /* ── Keywords Benefits Grid ── */
  .pro-keywords-section {
    margin: 6rem 0 4rem;
    padding: 0 1rem;
  }
  .pro-keywords-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    max-width: 1100px;
    margin: 0 auto;
  }
  .pro-keyword-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 14px;
    padding: 2rem 1.75rem;
    transition: all 0.3s ease;
  }
  .pro-keyword-card:hover {
    border-color: var(--color-border-hover);
    background: var(--color-bg-card-hover);
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0, 212, 170, 0.08);
  }
  .keyword-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: rgba(0, 212, 170, 0.1);
    color: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
    border: 1px solid rgba(0, 212, 170, 0.15);
  }
  .keyword-icon.accent {
    background: rgba(139, 92, 246, 0.1);
    color: var(--color-accent);
    border-color: rgba(139, 92, 246, 0.15);
  }
  .pro-keyword-card h3 {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 0.6rem;
    color: var(--color-text-primary);
  }
  .pro-keyword-card p {
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--color-text-secondary);
    margin: 0;
  }

  /* ── CTA ── */
  .final-cta {
    border-top: 1px solid var(--color-border);
    background: linear-gradient(180deg, rgba(255,255,255,0) 0%, rgba(0, 212, 170, 0.04) 100%);
    border-radius: 16px;
  }
  .cta-btn {
    display: inline-block;
    padding: 1rem 2.5rem;
    font-size: 1.1rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 8px;
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
    color: #ffffff;
    transition: all 0.2s ease;
    box-shadow: 0 8px 24px rgba(0, 212, 170, 0.22);
  }
  .cta-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(139, 92, 246, 0.22);
    background: linear-gradient(135deg, var(--color-accent), var(--color-primary));
    color: #ffffff !important;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .pro-feature-inner,
    .pro-feature-inner.reverse {
      flex-direction: column;
      padding: 2rem 1.5rem;
      gap: 1.5rem;
    }
    .pro-feature-icon-wrap {
      flex-direction: row;
    }
    .pro-feature-heading {
      font-size: 1.4rem;
    }
    .pro-keywords-grid {
      grid-template-columns: 1fr;
    }
    .final-cta {
      padding: 2rem 1rem !important;
    }
  }
  @media (min-width: 769px) and (max-width: 1024px) {
    .pro-keywords-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
