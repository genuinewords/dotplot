---
---

<div id="real-examples-tool" class="rex-wrapper">
  <style is:inline>
    .rex-wrapper {
      --bg: #0a0f14;
      --bg-elevated: #111920;
      --fg: #e8eef4;
      --muted: #6b7d8f;
      --accent: #00d4aa;
      --accent-dim: rgba(0, 212, 170, 0.15);
      --card: #151d26;
      --border: #243040;
      --purple: #8b5cf6;
      --orange: #f59e0b;

      font-family: 'Inter', system-ui, sans-serif;
      background: var(--bg);
      color: var(--fg);
      position: relative;
      overflow: hidden;
      border-radius: 16px;
      margin: 2rem auto;
      max-width: 900px;
      padding: 2rem;
      box-shadow: 0 20px 40px -12px rgba(0, 212, 170, 0.1), 0 0 0 1px rgba(255,255,255,0.07);
    }
    .rex-wrapper * { box-sizing: border-box; }

    .rex-wrapper .rex-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 1.25rem;
      flex-wrap: wrap;
      gap: 0.5rem;
    }
    .rex-wrapper .rex-header h3 {
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--accent);
      margin: 0;
    }
    .rex-wrapper .rex-header span {
      font-size: 0.8rem;
      color: var(--muted);
    }

    .rex-wrapper .rex-tabs {
      display: flex;
      gap: 0.5rem;
      margin-bottom: 1.25rem;
      flex-wrap: wrap;
    }
    .rex-wrapper .rex-tab {
      padding: 0.6rem 1.2rem;
      border: 1px solid var(--border);
      border-radius: 10px;
      background: var(--card);
      color: var(--muted);
      font-size: 0.85rem;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.2s;
    }
    .rex-wrapper .rex-tab:hover {
      border-color: var(--accent);
      color: var(--fg);
    }
    .rex-wrapper .rex-tab.active {
      background: var(--accent-dim);
      border-color: var(--accent);
      color: var(--accent);
    }

    .rex-wrapper .rex-chart-area {
      background: var(--bg-elevated);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.5rem;
      margin-bottom: 1.25rem;
      min-height: 300px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .rex-wrapper .rex-chart-area svg {
      width: 100%;
      max-height: 320px;
    }

    .rex-wrapper .rex-dataset-info {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1rem 1.25rem;
      margin-bottom: 1rem;
    }
    .rex-wrapper .rex-dataset-title {
      font-size: 0.95rem;
      font-weight: 700;
      color: var(--fg);
      margin-bottom: 0.35rem;
    }
    .rex-wrapper .rex-dataset-desc {
      font-size: 0.82rem;
      color: var(--muted);
      line-height: 1.5;
    }

    .rex-wrapper .rex-stats-row {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(90px, 1fr));
      gap: 0.6rem;
    }
    .rex-wrapper .rex-stat {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 0.6rem 0.75rem;
      text-align: center;
    }
    .rex-wrapper .rex-stat-label {
      font-size: 0.65rem;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 0.15rem;
    }
    .rex-wrapper .rex-stat-value {
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--fg);
    }
    .rex-wrapper .rex-stat-value.accent { color: var(--accent); }
    .rex-wrapper .rex-stat-value.purple { color: var(--purple); }
    .rex-wrapper .rex-stat-value.orange { color: var(--orange); }

    .rex-wrapper .rex-raw-data {
      margin-top: 1rem;
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 0.75rem 1rem;
    }
    .rex-wrapper .rex-raw-label {
      font-size: 0.7rem;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 0.3rem;
    }
    .rex-wrapper .rex-raw-values {
      font-size: 0.82rem;
      color: var(--fg);
      font-family: 'IBM Plex Mono', monospace;
      line-height: 1.5;
      word-break: break-all;
    }

    @media (max-width: 600px) {
      .rex-wrapper { padding: 1.25rem; }
      .rex-wrapper .rex-stats-row { grid-template-columns: repeat(3, 1fr); }
    }
  </style>

  <div class="rex-header">
    <h3>Real-World Dot Plot Explorer</h3>
    <span>Switch datasets to explore different scenarios</span>
  </div>

  <div class="rex-tabs">
    <button class="rex-tab active" data-set="salary">Salaries</button>
    <button class="rex-tab" data-set="exam">Exam Scores</button>
    <button class="rex-tab" data-set="sports">Sports Stats</button>
  </div>

  <div class="rex-dataset-info" id="rex-info">
    <div class="rex-dataset-title" id="rex-title">Tech Company Salaries ($K)</div>
    <div class="rex-dataset-desc" id="rex-desc">Annual salaries of 30 employees at a mid-size tech company. Notice the right-skewed distribution with a few high earners.</div>
  </div>

  <div class="rex-chart-area" id="rex-chart"></div>

  <div class="rex-stats-row" id="rex-stats"></div>

  <div class="rex-raw-data">
    <div class="rex-raw-label">Raw Data</div>
    <div class="rex-raw-values" id="rex-raw"></div>
  </div>
</div>

<script>
  const datasets: Record<string, { title: string; desc: string; data: number[]; unit: string; color: string }> = {
    salary: {
      title: "Tech Company Salaries ($K)",
      desc: "Annual salaries of 30 employees at a mid-size tech company. Notice the right-skewed distribution with a few high earners.",
      data: [42, 45, 48, 50, 52, 55, 55, 58, 60, 62, 65, 65, 68, 70, 72, 75, 78, 80, 85, 90, 95, 100, 110, 120, 130, 145, 160, 185, 210, 250],
      unit: "$K",
      color: "#00d4aa"
    },
    exam: {
      title: "College Exam Scores (out of 100)",
      desc: "Final exam scores for 35 students in an introductory statistics course. The distribution is roughly normal, centered around 72.",
      data: [28, 35, 42, 48, 52, 55, 58, 60, 62, 63, 65, 66, 68, 69, 70, 71, 72, 72, 73, 74, 75, 76, 78, 79, 80, 82, 84, 86, 88, 90, 92, 95, 98, 55, 67],
      unit: "pts",
      color: "#8b5cf6"
    },
    sports: {
      title: "NBA Player Points Per Game (2024-25)",
      desc: "Points per game for 30 NBA players. Most score between 8-18 PPG, with a few star players scoring 25+.",
      data: [3.2, 4.8, 5.5, 6.1, 7.3, 8.0, 8.8, 9.5, 10.2, 10.8, 11.5, 12.0, 12.8, 13.5, 14.2, 15.0, 15.8, 16.5, 17.2, 18.0, 19.5, 20.3, 21.8, 23.1, 24.5, 26.2, 27.8, 29.5, 31.0, 33.2],
      unit: "PPG",
      color: "#f59e0b"
    }
  };

  function calcStats(data: number[]) {
    const sorted = [...data].sort((a, b) => a - b);
    const n = sorted.length;
    const mean = data.reduce((a, b) => a + b, 0) / n;
    const median = n % 2 === 0 ? (sorted[n / 2 - 1] + sorted[n / 2]) / 2 : sorted[Math.floor(n / 2)];
    const min = sorted[0];
    const max = sorted[n - 1];
    const stdDev = Math.sqrt(data.reduce((s, v) => s + Math.pow(v - mean, 2), 0) / n);
    return { mean, median, min, max, stdDev, n };
  }

  function renderDataset(key: string) {
    const ds = datasets[key];
    if (!ds) return;

    const stats = calcStats(ds.data);
    const sorted = [...ds.data].sort((a, b) => a - b);

    (document.getElementById("rex-title") as HTMLElement).textContent = ds.title;
    (document.getElementById("rex-desc") as HTMLElement).textContent = ds.desc;
    (document.getElementById("rex-raw") as HTMLElement).textContent = ds.data.join(", ");

    document.querySelectorAll(".rex-tab").forEach(t => {
      t.classList.toggle("active", t.getAttribute("data-set") === key);
    });

    const W = 860, H = 300;
    const pad = { top: 25, right: 30, bottom: 45, left: 50 };
    const cw = W - pad.left - pad.right;
    const ch = H - pad.top - pad.bottom;

    const min = stats.min;
    const max = stats.max;
    const range = max - min || 1;
    const scaleX = (v: number) => pad.left + ((v - min) / range) * cw;

    const freq: Record<string, number> = {};
    sorted.forEach(v => {
      const k = v.toString();
      freq[k] = (freq[k] || 0) + 1;
    });
    const maxFreq = Math.max(...Object.values(freq));
    const dotSpacing = Math.min(14, ch / (maxFreq + 2));
    const baseY = H - pad.bottom;

    let svg = `<svg viewBox="0 0 ${W} ${H}" xmlns="http://www.w3.org/2000/svg">`;

    const gridSteps = 8;
    for (let i = 0; i <= gridSteps; i++) {
      const v = min + (range * i) / gridSteps;
      const x = scaleX(v);
      svg += `<line x1="${x}" y1="${pad.top}" x2="${x}" y2="${H - pad.bottom}" stroke="#243040" stroke-width="1" />`;
      svg += `<text x="${x}" y="${H - pad.bottom + 22}" text-anchor="middle" fill="#6b7d8f" font-size="11">${v < 10 ? v.toFixed(1) : Math.round(v)}</text>`;
    }

    svg += `<text x="${pad.left + cw / 2}" y="${H - 5}" text-anchor="middle" fill="#6b7d8f" font-size="11">${ds.unit}</text>`;

    const freqTracker: Record<string, number> = {};
    sorted.forEach(v => {
      const k = v.toString();
      freqTracker[k] = (freqTracker[k] || 0) + 1;
      const stackIdx = freqTracker[k]! - 1;
      const cx = scaleX(v);
      const cy = baseY - stackIdx * dotSpacing - 10;
      svg += `<circle cx="${cx}" cy="${cy}" r="5.5" fill="${ds.color}" opacity="${0.4 + 0.6 * (1 - stackIdx / maxFreq)}" />`;
    });

    const medX = scaleX(stats.median);
    svg += `<line x1="${medX}" y1="${pad.top}" x2="${medX}" y2="${baseY}" stroke="${ds.color}" stroke-width="2" stroke-dasharray="4,3" opacity="0.6" />`;
    svg += `<text x="${medX}" y="${pad.top - 6}" text-anchor="middle" fill="${ds.color}" font-size="10" font-weight="600">Median</text>`;

    svg += `</svg>`;
    (document.getElementById("rex-chart") as HTMLElement).innerHTML = svg;

    const statsEl = document.getElementById("rex-stats") as HTMLElement;
    const f = (v: number) => v < 10 ? v.toFixed(2) : v < 100 ? v.toFixed(1) : Math.round(v).toString();
    statsEl.innerHTML = `
      <div class="rex-stat"><div class="rex-stat-label">Count</div><div class="rex-stat-value">${stats.n}</div></div>
      <div class="rex-stat"><div class="rex-stat-label">Min</div><div class="rex-stat-value">${f(stats.min)}</div></div>
      <div class="rex-stat"><div class="rex-stat-label">Median</div><div class="rex-stat-value accent">${f(stats.median)}</div></div>
      <div class="rex-stat"><div class="rex-stat-label">Mean</div><div class="rex-stat-value purple">${f(stats.mean)}</div></div>
      <div class="rex-stat"><div class="rex-stat-label">Max</div><div class="rex-stat-value">${f(stats.max)}</div></div>
      <div class="rex-stat"><div class="rex-stat-label">Std Dev</div><div class="rex-stat-value orange">${f(stats.stdDev)}</div></div>
    `;
  }

  document.querySelectorAll(".rex-tab").forEach(tab => {
    tab.addEventListener("click", () => {
      renderDataset(tab.getAttribute("data-set") || "salary");
    });
  });

  renderDataset("salary");
</script>
