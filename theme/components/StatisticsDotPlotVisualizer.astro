---
---

<div id="stats-viz-tool" class="svt-wrapper">
  <style is:inline>
    .svt-wrapper {
      --bg: #0a0f14; --bg-elevated: #111920; --fg: #e8eef4; --muted: #6b7d8f;
      --accent: #00d4aa; --card: #151d26; --border: #243040;
      --purple: #8b5cf6; --orange: #f59e0b; --red: #ff6b6b;
      font-family: 'Inter', system-ui, sans-serif;
      background: var(--bg); color: var(--fg); position: relative; overflow: hidden;
      border-radius: 16px; margin: 2rem auto; max-width: 900px; padding: 2rem;
      box-shadow: 0 20px 40px -12px rgba(0,212,170,0.1), 0 0 0 1px rgba(255,255,255,0.07);
    }
    .svt-wrapper * { box-sizing: border-box; }
    .svt-wrapper .svt-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.25rem; flex-wrap: wrap; gap: 0.5rem; }
    .svt-wrapper .svt-header h3 { font-size: 1.1rem; font-weight: 700; color: var(--accent); margin: 0; }
    .svt-wrapper .svt-header span { font-size: 0.8rem; color: var(--muted); }
    .svt-wrapper .svt-tabs { display: flex; gap: 0.5rem; margin-bottom: 1rem; flex-wrap: wrap; }
    .svt-wrapper .svt-tab {
      padding: 0.55rem 1.1rem; border: 1px solid var(--border); border-radius: 10px;
      background: var(--card); color: var(--muted); font-size: 0.82rem; font-weight: 500;
      cursor: pointer; transition: all 0.2s;
    }
    .svt-wrapper .svt-tab:hover { border-color: var(--accent); color: var(--fg); }
    .svt-wrapper .svt-tab.active { background: rgba(0,212,170,0.15); border-color: var(--accent); color: var(--accent); }
    .svt-wrapper .svt-input-row { display: flex; gap: 0.75rem; margin-bottom: 1.25rem; flex-wrap: wrap; }
    .svt-wrapper .svt-input {
      flex: 1; min-width: 200px; background: var(--card); border: 1px solid var(--border);
      border-radius: 10px; padding: 0.75rem 1rem; color: var(--fg); font-size: 0.88rem;
      outline: none; transition: border-color 0.2s; font-family: 'IBM Plex Mono', monospace;
    }
    .svt-wrapper .svt-input:focus { border-color: var(--accent); }
    .svt-wrapper .svt-input::placeholder { color: var(--muted); }
    .svt-wrapper .svt-btn { padding: 0.7rem 1.4rem; border: none; border-radius: 10px; font-weight: 600; font-size: 0.88rem; cursor: pointer; transition: all 0.2s; }
    .svt-wrapper .svt-btn-primary { background: linear-gradient(135deg, var(--accent), #00b894); color: #0a0f14; }
    .svt-wrapper .svt-btn-primary:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(0,212,170,0.3); }
    .svt-wrapper .svt-btn-secondary { background: var(--card); color: var(--fg); border: 1px solid var(--border); }
    .svt-wrapper .svt-btn-secondary:hover { border-color: var(--accent); }
    .svt-wrapper .svt-chart-area {
      background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 12px;
      padding: 1.5rem; margin-bottom: 1.25rem; min-height: 280px;
      display: flex; align-items: center; justify-content: center;
    }
    .svt-wrapper .svt-chart-area svg { width: 100%; max-height: 320px; }
    .svt-wrapper .svt-stats-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(100px, 1fr)); gap: 0.6rem;
      margin-bottom: 1rem;
    }
    .svt-wrapper .svt-stat {
      background: var(--card); border: 1px solid var(--border); border-radius: 8px;
      padding: 0.6rem 0.75rem; text-align: center;
    }
    .svt-wrapper .svt-stat-label { font-size: 0.65rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.15rem; }
    .svt-wrapper .svt-stat-value { font-size: 1.05rem; font-weight: 700; color: var(--fg); }
    .svt-wrapper .svt-stat-value.accent { color: var(--accent); }
    .svt-wrapper .svt-stat-value.purple { color: var(--purple); }
    .svt-wrapper .svt-stat-value.orange { color: var(--orange); }
    .svt-wrapper .svt-stat-value.red { color: var(--red); }
    .svt-wrapper .svt-dist-note {
      background: var(--card); border: 1px solid var(--border); border-radius: 10px;
      padding: 0.75rem 1rem; font-size: 0.82rem; color: var(--muted); line-height: 1.5;
    }
    .svt-wrapper .svt-dist-note strong { color: var(--fg); }
    @media (max-width: 600px) {
      .svt-wrapper { padding: 1.25rem; }
      .svt-wrapper .svt-stats-grid { grid-template-columns: repeat(3, 1fr); }
    }
  </style>

  <div class="svt-header">
    <h3>Statistics Dot Plot Visualizer</h3>
    <span>Visualize descriptive statistics on real datasets</span>
  </div>

  <div class="svt-tabs">
    <button class="svt-tab active" data-set="heights">Heights (cm)</button>
    <button class="svt-tab" data-set="temps">Temperatures (°F)</button>
    <button class="svt-tab" data-set="rainfall">Rainfall (mm)</button>
    <button class="svt-tab" data-set="custom">Custom</button>
  </div>

  <div class="svt-input-row" id="svt-custom-row" style="display:none;">
    <input type="text" class="svt-input" id="svt-custom-data" placeholder="Enter comma-separated numbers" />
    <button class="svt-btn svt-btn-primary" id="svt-custom-go">Visualize</button>
  </div>

  <div class="svt-chart-area" id="svt-chart"></div>

  <div class="svt-stats-grid" id="svt-stats"></div>

  <div class="svt-dist-note" id="svt-note"></div>
</div>

<script>
  const presets: Record<string, { data: number[]; label: string; unit: string; note: string }> = {
    heights: {
      data: [152,155,157,158,160,161,162,163,164,165,165,166,167,168,168,169,170,170,171,172,173,174,175,176,177,178,180,182,184,187,190,193],
      label: "Adult Heights", unit: "cm",
      note: "This distribution is <strong>approximately normal</strong> — most values cluster around the center with symmetrical tails. The mean and median are very close, which is a hallmark of normal distributions."
    },
    temps: {
      data: [32,35,38,42,45,48,52,55,58,62,65,68,72,75,78,82,85,88,92,95,98,100,105,112],
      label: "Annual High Temperatures", unit: "°F",
      note: "This distribution shows a <strong>slight right skew</strong> — a few extremely hot days pull the mean slightly above the median. The dot plot reveals the long right tail clearly."
    },
    rainfall: {
      data: [0,2,5,8,10,12,15,18,22,25,30,35,42,55,68,85,120],
      label: "Monthly Rainfall", unit: "mm",
      note: "This is a <strong>strongly right-skewed</strong> distribution — most months have low rainfall, but a few flood months create a long right tail. The mean is much higher than the median, showing how outliers affect the mean."
    }
  };

  function quartile(sorted: number[], q: number) {
    const pos = (sorted.length - 1) * q;
    const base = Math.floor(pos);
    const rest = pos - base;
    return sorted[base + 1] !== undefined ? sorted[base] + rest * (sorted[base + 1] - sorted[base]) : sorted[base];
  }

  function calcAll(data: number[]) {
    const sorted = [...data].sort((a, b) => a - b);
    const n = sorted.length;
    const mean = data.reduce((a, b) => a + b, 0) / n;
    const median = quartile(sorted, 0.5);
    const q1 = quartile(sorted, 0.25);
    const q3 = quartile(sorted, 0.75);
    const iqr = q3 - q1;
    const stdDev = Math.sqrt(data.reduce((s, v) => s + (v - mean) ** 2, 0) / n);
    const outliers = sorted.filter(v => v < q1 - 1.5 * iqr || v > q3 + 1.5 * iqr);
    const skewness = data.reduce((s, v) => s + ((v - mean) / stdDev) ** 3, 0) / n;
    return { min: sorted[0], max: sorted[n-1], mean, median, q1, q3, iqr, stdDev, outliers, skewness, n };
  }

  function render(data: number[], label: string, unit: string, note: string) {
    if (data.length < 3) return;
    const s = calcAll(data);
    const sorted = [...data].sort((a, b) => a - b);

    const W = 860, H = 280, pad = { t: 30, r: 30, b: 45, l: 50 };
    const cw = W - pad.l - pad.r, ch = H - pad.t - pad.b;
    const range = s.max - s.min || 1;
    const sx = (v: number) => pad.l + ((v - s.min) / range) * cw;
    const baseY = H - pad.b;

    let svg = `<svg viewBox="0 0 ${W} ${H}" xmlns="http://www.w3.org/2000/svg">`;

    for (let i = 0; i <= 8; i++) {
      const v = s.min + (range * i) / 8;
      const x = sx(v);
      svg += `<line x1="${x}" y1="${pad.t}" x2="${x}" y2="${baseY}" stroke="#243040" stroke-width="1"/>`;
      svg += `<text x="${x}" y="${baseY+20}" text-anchor="middle" fill="#6b7d8f" font-size="10">${Math.round(v)}</text>`;
    }

    svg += `<text x="${pad.l+cw/2}" y="${baseY+38}" text-anchor="middle" fill="#6b7d8f" font-size="10">${unit}</text>`;

    const freq: Record<string,number> = {};
    sorted.forEach(v => { const k=String(v); freq[k]=(freq[k]||0)+1; });
    const maxF = Math.max(...Object.values(freq));
    const ds = Math.min(14, ch/(maxF+2));
    const fT: Record<string,number> = {};

    sorted.forEach(v => {
      const k = String(v); fT[k] = (fT[k]||0)+1;
      const si = fT[k]!-1;
      const isOut = s.outliers.includes(v);
      const fill = isOut ? "#ff6b6b" : "#00d4aa";
      svg += `<circle cx="${sx(v)}" cy="${baseY - si*ds - 10}" r="5.5" fill="${fill}" opacity="${isOut?0.9:0.65}"/>`;
    });

    svg += `<line x1="${sx(s.mean)}" y1="${pad.t}" x2="${sx(s.mean)}" y2="${baseY}" stroke="#f59e0b" stroke-width="2" stroke-dasharray="6,3" opacity="0.7"/>`;
    svg += `<text x="${sx(s.mean)}" y="${pad.t-6}" text-anchor="middle" fill="#f59e0b" font-size="9" font-weight="600">Mean</text>`;

    svg += `<line x1="${sx(s.median)}" y1="${pad.t}" x2="${sx(s.median)}" y2="${baseY}" stroke="#00d4aa" stroke-width="2" stroke-dasharray="3,3" opacity="0.7"/>`;
    svg += `<text x="${sx(s.median)}" y="${pad.t+10}" text-anchor="middle" fill="#00d4aa" font-size="9" font-weight="600">Median</text>`;

    svg += `</svg>`;
    (document.getElementById("svt-chart") as HTMLElement).innerHTML = svg;

    const f = (v: number) => v < 10 ? v.toFixed(2) : v < 100 ? v.toFixed(1) : Math.round(v).toString();
    const skew = s.skewness > 0.5 ? "Right-skewed" : s.skewness < -0.5 ? "Left-skewed" : "Approximately symmetric";
    (document.getElementById("svt-stats") as HTMLElement).innerHTML = `
      <div class="svt-stat"><div class="svt-stat-label">n</div><div class="svt-stat-value">${s.n}</div></div>
      <div class="svt-stat"><div class="svt-stat-label">Min</div><div class="svt-stat-value">${f(s.min)}</div></div>
      <div class="svt-stat"><div class="svt-stat-label">Q1</div><div class="svt-stat-value purple">${f(s.q1)}</div></div>
      <div class="svt-stat"><div class="svt-stat-label">Median</div><div class="svt-stat-value accent">${f(s.median)}</div></div>
      <div class="svt-stat"><div class="svt-stat-label">Mean</div><div class="svt-stat-value orange">${f(s.mean)}</div></div>
      <div class="svt-stat"><div class="svt-stat-label">Q3</div><div class="svt-stat-value purple">${f(s.q3)}</div></div>
      <div class="svt-stat"><div class="svt-stat-label">Max</div><div class="svt-stat-value">${f(s.max)}</div></div>
      <div class="svt-stat"><div class="svt-stat-label">Std Dev</div><div class="svt-stat-value">${f(s.stdDev)}</div></div>
      <div class="svt-stat"><div class="svt-stat-label">IQR</div><div class="svt-stat-value">${f(s.iqr)}</div></div>
      <div class="svt-stat"><div class="svt-stat-label">Outliers</div><div class="svt-stat-value red">${s.outliers.length > 0 ? s.outliers.map(v=>f(v)).join(", ") : "None"}</div></div>
      <div class="svt-stat"><div class="svt-stat-label">Shape</div><div class="svt-stat-value accent" style="font-size:0.82rem">${skew}</div></div>
    `;

    (document.getElementById("svt-note") as HTMLElement).innerHTML = note;
  }

  let currentSet = "heights";

  document.querySelectorAll(".svt-tab").forEach(tab => {
    tab.addEventListener("click", () => {
      const key = tab.getAttribute("data-set") || "heights";
      currentSet = key;
      document.querySelectorAll(".svt-tab").forEach(t => t.classList.toggle("active", t === tab));
      const customRow = document.getElementById("svt-custom-row") as HTMLElement;
      if (key === "custom") {
        customRow.style.display = "flex";
      } else {
        customRow.style.display = "none";
        const p = presets[key];
        render(p.data, p.label, p.unit, p.note);
      }
    });
  });

  document.getElementById("svt-custom-go")?.addEventListener("click", () => {
    const raw = (document.getElementById("svt-custom-data") as HTMLInputElement).value;
    const data = raw.split(/[,\s]+/).map(Number).filter(n => !isNaN(n));
    render(data, "Custom Data", "units", "<strong>Custom dataset</strong> — the shape, spread, and outlier analysis above describe your entered data.");
  });

  const init = presets.heights;
  render(init.data, init.label, init.unit, init.note);
</script>
