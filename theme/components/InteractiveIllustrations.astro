<script>
  const cards = document.querySelectorAll(".illustration-card[data-tilt]");
  const tiltEnabled = window.matchMedia("(pointer: fine)").matches;

  if (tiltEnabled) {
    cards.forEach((card) => {
      let cachedRect = null;

      card.addEventListener("mouseenter", () => {
        cachedRect = card.getBoundingClientRect();
      });

      card.addEventListener("mousemove", (event) => {
        if (!cachedRect) return;
        const px = (event.clientX - cachedRect.left) / cachedRect.width;
        const py = (event.clientY - cachedRect.top) / cachedRect.height;
        const rx = (0.5 - py) * 7;
        const ry = (px - 0.5) * 8;
        card.style.setProperty("--rx", `${rx.toFixed(2)}deg`);
        card.style.setProperty("--ry", `${ry.toFixed(2)}deg`);
        card.style.setProperty("--mx", `${(px * 100).toFixed(1)}%`);
        card.style.setProperty("--my", `${(py * 100).toFixed(1)}%`);
      });

      card.addEventListener("mouseleave", () => {
        cachedRect = null;
        card.style.setProperty("--rx", "0deg");
        card.style.setProperty("--ry", "0deg");
        card.style.setProperty("--mx", "50%");
        card.style.setProperty("--my", "50%");
      });
    });
  }
</script>

