---
---

<div id="whisker-tool" class="whisker-wrapper">
  <style is:inline>
    .whisker-wrapper {
      --bg: #0a0f14;
      --bg-elevated: #111920;
      --fg: #e8eef4;
      --muted: #6b7d8f;
      --accent: #00d4aa;
      --accent-dim: rgba(0, 212, 170, 0.15);
      --card: #151d26;
      --border: #243040;
      --purple: #8b5cf6;
      --purple-dim: rgba(139, 92, 246, 0.15);

      font-family: 'Inter', system-ui, sans-serif;
      background: var(--bg);
      color: var(--fg);
      position: relative;
      overflow: hidden;
      border-radius: 16px;
      margin: 2rem auto;
      max-width: 900px;
      padding: 2rem;
      box-shadow: 0 20px 40px -12px rgba(0, 212, 170, 0.1), 0 0 0 1px rgba(255,255,255,0.07);
    }
    .whisker-wrapper * { box-sizing: border-box; }

    .whisker-wrapper .wt-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 1.5rem;
      flex-wrap: wrap;
      gap: 0.5rem;
    }
    .whisker-wrapper .wt-header h3 {
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--accent);
      margin: 0;
    }
    .whisker-wrapper .wt-header span {
      font-size: 0.8rem;
      color: var(--muted);
    }

    .whisker-wrapper .wt-input-row {
      display: flex;
      gap: 0.75rem;
      margin-bottom: 1.25rem;
      flex-wrap: wrap;
    }
    .whisker-wrapper .wt-input {
      flex: 1;
      min-width: 200px;
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 0.75rem 1rem;
      color: var(--fg);
      font-size: 0.9rem;
      outline: none;
      transition: border-color 0.2s;
    }
    .whisker-wrapper .wt-input:focus {
      border-color: var(--accent);
    }
    .whisker-wrapper .wt-input::placeholder {
      color: var(--muted);
    }
    .whisker-wrapper .wt-btn {
      padding: 0.75rem 1.5rem;
      border: none;
      border-radius: 10px;
      font-weight: 600;
      font-size: 0.9rem;
      cursor: pointer;
      transition: all 0.2s;
    }
    .whisker-wrapper .wt-btn-primary {
      background: linear-gradient(135deg, var(--accent), #00b894);
      color: #0a0f14;
    }
    .whisker-wrapper .wt-btn-primary:hover {
      transform: translateY(-1px);
      box-shadow: 0 6px 20px rgba(0, 212, 170, 0.3);
    }
    .whisker-wrapper .wt-btn-secondary {
      background: var(--card);
      color: var(--fg);
      border: 1px solid var(--border);
    }
    .whisker-wrapper .wt-btn-secondary:hover {
      border-color: var(--accent);
    }

    .whisker-wrapper .wt-chart-area {
      background: var(--bg-elevated);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.5rem;
      margin-bottom: 1.25rem;
      min-height: 280px;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
    }
    .whisker-wrapper .wt-chart-area svg {
      width: 100%;
      max-height: 300px;
    }
    .whisker-wrapper .wt-placeholder {
      color: var(--muted);
      font-size: 0.95rem;
      text-align: center;
    }

    .whisker-wrapper .wt-stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
      gap: 0.75rem;
    }
    .whisker-wrapper .wt-stat-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 0.75rem 1rem;
      text-align: center;
    }
    .whisker-wrapper .wt-stat-label {
      font-size: 0.7rem;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 0.25rem;
    }
    .whisker-wrapper .wt-stat-value {
      font-size: 1.15rem;
      font-weight: 700;
      color: var(--fg);
    }
    .whisker-wrapper .wt-stat-value.accent { color: var(--accent); }
    .whisker-wrapper .wt-stat-value.purple { color: var(--purple); }

    .whisker-wrapper .wt-legend {
      display: flex;
      gap: 1.25rem;
      margin-top: 1rem;
      flex-wrap: wrap;
    }
    .whisker-wrapper .wt-legend-item {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.78rem;
      color: var(--muted);
    }
    .whisker-wrapper .wt-legend-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
    }

    @media (max-width: 600px) {
      .whisker-wrapper { padding: 1.25rem; }
      .whisker-wrapper .wt-stats-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }
  </style>

  <div class="wt-header">
    <h3>Dot &amp; Whisker Plot Generator</h3>
    <span>Free · No signup · Data stays in browser</span>
  </div>

  <div class="wt-input-row">
    <input type="text" class="wt-input" id="whisker-data" placeholder="Enter numbers separated by commas (e.g., 3, 5, 5, 7, 8, 9, 10, 12, 14, 15, 16, 18, 22)" />
    <button class="wt-btn wt-btn-primary" id="whisker-generate">Generate</button>
    <button class="wt-btn wt-btn-secondary" id="whisker-reset">Reset</button>
  </div>

  <div class="wt-chart-area" id="whisker-chart">
    <div class="wt-placeholder">Enter your data above and click Generate to see both plots</div>
  </div>

  <div class="wt-stats-grid" id="whisker-stats" style="display:none;">
    <div class="wt-stat-card"><div class="wt-stat-label">Min</div><div class="wt-stat-value" id="ws-min">—</div></div>
    <div class="wt-stat-card"><div class="wt-stat-label">Q1</div><div class="wt-stat-value purple" id="ws-q1">—</div></div>
    <div class="wt-stat-card"><div class="wt-stat-label">Median</div><div class="wt-stat-value accent" id="ws-med">—</div></div>
    <div class="wt-stat-card"><div class="wt-stat-label">Q3</div><div class="wt-stat-value purple" id="ws-q3">—</div></div>
    <div class="wt-stat-card"><div class="wt-stat-label">Max</div><div class="wt-stat-value" id="ws-max">—</div></div>
    <div class="wt-stat-card"><div class="wt-stat-label">IQR</div><div class="wt-stat-value" id="ws-iqr">—</div></div>
    <div class="wt-stat-card"><div class="wt-stat-label">Mean</div><div class="wt-stat-value" id="ws-mean">—</div></div>
    <div class="wt-stat-card"><div class="wt-stat-label">Outliers</div><div class="wt-stat-value accent" id="ws-out">—</div></div>
  </div>

  <div class="wt-legend" id="whisker-legend" style="display:none;">
    <div class="wt-legend-item"><div class="wt-legend-dot" style="background:#8b5cf6;"></div>Box (Q1–Q3)</div>
    <div class="wt-legend-item"><div class="wt-legend-dot" style="background:#00d4aa;"></div>Median</div>
    <div class="wt-legend-item"><div class="wt-legend-dot" style="background:rgba(0,212,170,0.5);"></div>Data points</div>
    <div class="wt-legend-item"><div class="wt-legend-dot" style="background:#ff6b6b;"></div>Outliers</div>
  </div>
</div>

<script>
  function quartile(sorted: number[], q: number): number {
    const pos = (sorted.length - 1) * q;
    const base = Math.floor(pos);
    const rest = pos - base;
    if (sorted[base + 1] !== undefined) {
      return sorted[base] + rest * (sorted[base + 1] - sorted[base]);
    }
    return sorted[base];
  }

  function generatePlots() {
    const input = (document.getElementById("whisker-data") as HTMLInputElement)?.value?.trim();
    if (!input) return;

    const nums = input.split(/[,\s]+/).map(Number).filter((n: number) => !isNaN(n));
    if (nums.length < 5) {
      (document.getElementById("whisker-chart") as HTMLElement).innerHTML =
        '<div class="wt-placeholder">Please enter at least 5 numbers</div>';
      return;
    }

    const sorted = [...nums].sort((a, b) => a - b);
    const min = sorted[0];
    const max = sorted[sorted.length - 1];
    const q1 = quartile(sorted, 0.25);
    const med = quartile(sorted, 0.5);
    const q3 = quartile(sorted, 0.75);
    const iqr = q3 - q1;
    const lowerFence = q1 - 1.5 * iqr;
    const upperFence = q3 + 1.5 * iqr;
    const mean = nums.reduce((a: number, b: number) => a + b, 0) / nums.length;

    const whiskerLow = sorted.find((v: number) => v >= lowerFence) ?? min;
    const whiskerHigh = [...sorted].reverse().find((v: number) => v <= upperFence) ?? max;
    const outliers = sorted.filter((v: number) => v < lowerFence || v > upperFence);

    (document.getElementById("ws-min") as HTMLElement).textContent = min.toFixed(2);
    (document.getElementById("ws-q1") as HTMLElement).textContent = q1.toFixed(2);
    (document.getElementById("ws-med") as HTMLElement).textContent = med.toFixed(2);
    (document.getElementById("ws-q3") as HTMLElement).textContent = q3.toFixed(2);
    (document.getElementById("ws-max") as HTMLElement).textContent = max.toFixed(2);
    (document.getElementById("ws-iqr") as HTMLElement).textContent = iqr.toFixed(2);
    (document.getElementById("ws-mean") as HTMLElement).textContent = mean.toFixed(2);
    (document.getElementById("ws-out") as HTMLElement).textContent = outliers.length > 0 ? outliers.map((v: number) => v.toFixed(1)).join(", ") : "None";
    (document.getElementById("whisker-stats") as HTMLElement).style.display = "grid";
    (document.getElementById("whisker-legend") as HTMLElement).style.display = "flex";

    const W = 860, H = 280;
    const pad = { top: 30, right: 40, bottom: 40, left: 50 };
    const cw = W - pad.left - pad.right;
    const ch = H - pad.top - pad.bottom;

    const range = max - min || 1;
    const scaleX = (v: number) => pad.left + ((v - min) / range) * cw;
    const midY = pad.top + ch / 2;
    const boxH = 50;
    const dotH = 70;

    let svg = `<svg viewBox="0 0 ${W} ${H}" xmlns="http://www.w3.org/2000/svg">`;

    // Grid lines
    const steps = 8;
    for (let i = 0; i <= steps; i++) {
      const v = min + (range * i) / steps;
      const x = scaleX(v);
      svg += `<line x1="${x}" y1="${pad.top}" x2="${x}" y2="${H - pad.bottom}" stroke="#243040" stroke-width="1" />`;
      svg += `<text x="${x}" y="${H - pad.bottom + 20}" text-anchor="middle" fill="#6b7d8f" font-size="11">${v.toFixed(1)}</text>`;
    }

    // Whisker plot (upper half)
    const boxY = midY - boxH / 2 - dotH / 2 - 10;

    // Whisker lines
    svg += `<line x1="${scaleX(whiskerLow)}" y1="${boxY}" x2="${scaleX(q1)}" y2="${boxY}" stroke="#6b7d8f" stroke-width="2" />`;
    svg += `<line x1="${scaleX(q3)}" y1="${boxY}" x2="${scaleX(whiskerHigh)}" y2="${boxY}" stroke="#6b7d8f" stroke-width="2" />`;
    // Whisker caps
    svg += `<line x1="${scaleX(whiskerLow)}" y1="${boxY - 12}" x2="${scaleX(whiskerLow)}" y2="${boxY + 12}" stroke="#6b7d8f" stroke-width="2" />`;
    svg += `<line x1="${scaleX(whiskerHigh)}" y1="${boxY - 12}" x2="${scaleX(whiskerHigh)}" y2="${boxY + 12}" stroke="#6b7d8f" stroke-width="2" />`;

    // Box
    svg += `<rect x="${scaleX(q1)}" y="${boxY - boxH / 2}" width="${scaleX(q3) - scaleX(q1)}" height="${boxH}" fill="rgba(139,92,246,0.2)" stroke="#8b5cf6" stroke-width="2" rx="4" />`;

    // Median line
    svg += `<line x1="${scaleX(med)}" y1="${boxY - boxH / 2}" x2="${scaleX(med)}" y2="${boxY + boxH / 2}" stroke="#00d4aa" stroke-width="3" />`;

    // Outliers
    outliers.forEach((v: number) => {
      svg += `<circle cx="${scaleX(v)}" cy="${boxY}" r="5" fill="#ff6b6b" stroke="#ff6b6b" stroke-width="1.5" opacity="0.8" />`;
    });

    // Labels
    svg += `<text x="${scaleX(q1)}" y="${boxY - boxH / 2 - 6}" text-anchor="middle" fill="#8b5cf6" font-size="10" font-weight="600">Q1</text>`;
    svg += `<text x="${scaleX(med)}" y="${boxY - boxH / 2 - 6}" text-anchor="middle" fill="#00d4aa" font-size="10" font-weight="600">Med</text>`;
    svg += `<text x="${scaleX(q3)}" y="${boxY - boxH / 2 - 6}" text-anchor="middle" fill="#8b5cf6" font-size="10" font-weight="600">Q3</text>`;
    svg += `<text x="${pad.left + cw / 2}" y="${pad.top - 10}" text-anchor="middle" fill="#6b7d8f" font-size="11" font-weight="600">Whisker Plot</text>`;

    // Dot plot (lower half)
    const dotBaseY = midY + dotH / 2 + 20;
    const freq: Record<number, number> = {};
    sorted.forEach((v: number) => { freq[v] = (freq[v] || 0) + 1; });
    const maxFreq = Math.max(...Object.values(freq));

    sorted.forEach((v: number) => {
      const stackIdx = (freq[v] || 1) - 1;
      freq[v]! -= 1;
      const isOutlier = v < lowerFence || v > upperFence;
      const cy = dotBaseY - stackIdx * 12;
      const fill = isOutlier ? "#ff6b6b" : "rgba(0,212,170,0.6)";
      svg += `<circle cx="${scaleX(v)}" cy="${cy}" r="5" fill="${fill}" />`;
    });

    svg += `<text x="${pad.left + cw / 2}" y="${dotBaseY + 20}" text-anchor="middle" fill="#6b7d8f" font-size="11" font-weight="600">Dot Plot</text>`;

    svg += `</svg>`;
    (document.getElementById("whisker-chart") as HTMLElement).innerHTML = svg;
  }

  function resetTool() {
    (document.getElementById("whisker-data") as HTMLInputElement).value = "";
    (document.getElementById("whisker-chart") as HTMLElement).innerHTML =
      '<div class="wt-placeholder">Enter your data above and click Generate to see both plots</div>';
    (document.getElementById("whisker-stats") as HTMLElement).style.display = "none";
    (document.getElementById("whisker-legend") as HTMLElement).style.display = "none";
  }

  document.getElementById("whisker-generate")?.addEventListener("click", generatePlots);
  document.getElementById("whisker-reset")?.addEventListener("click", resetTool);
  document.getElementById("whisker-data")?.addEventListener("keydown", (e) => {
    if ((e as KeyboardEvent).key === "Enter") generatePlots();
  });
</script>
