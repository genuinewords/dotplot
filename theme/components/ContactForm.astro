---
import { type Locale, defaultLocale } from "@src/i18n/config";
import { t } from "@src/i18n/utils";
import siteConfig from "@src/config/site.json";

interface Props {
  locale?: Locale;
}

const { locale = defaultLocale } = Astro.props;
---

<div class="contact-form-wrapper">
  <form id="contact-form" class="contact-form" novalidate>
    <div class="form-group">
      <label for="contact-name" class="form-label">{t(locale, "contact.nameLabel")}</label>
      <input type="text" id="contact-name" name="name" class="form-input" placeholder={t(locale, "contact.namePlaceholder")} required />
    </div>
    <div class="form-group">
      <label for="contact-email" class="form-label">{t(locale, "contact.emailLabel")}</label>
      <input type="email" id="contact-email" name="email" class="form-input" placeholder={t(locale, "contact.emailPlaceholder")} required />
    </div>
    <div class="form-group">
      <label for="contact-message" class="form-label">{t(locale, "contact.messageLabel")}</label>
      <textarea id="contact-message" name="message" class="form-input" placeholder={t(locale, "contact.messagePlaceholder")} required></textarea>
    </div>
    <button type="submit" id="contact-submit" class="btn-primary">
      <span>{t(locale, "contact.submit")}</span>
    </button>
    <div id="contact-status" class="contact-status" aria-live="polite"></div>
  </form>

  <p class="contact-fallback">
    {t(locale, "contact.fallback")}
    <a href={`mailto:${siteConfig.contactEmail}`}>{siteConfig.contactEmail}</a>
  </p>
</div>

<style>
  .contact-form-wrapper {
    max-width: 600px;
  }
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .form-label {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text-secondary);
  }
  .contact-status {
    margin-top: 0.5rem;
    font-size: 0.92rem;
    line-height: 1.6;
    min-height: 1.5em;
  }
  .contact-status.success {
    color: var(--color-success);
  }
  .contact-status.error {
    color: var(--color-error);
  }
  .contact-fallback {
    color: var(--color-text-muted);
    font-size: 0.88rem;
  }
  .contact-fallback a {
    color: var(--color-primary);
  }
</style>

<script
  define:vars={{
    sendingText: t(locale, "contact.sending"),
    successText: t(locale, "contact.success"),
    errorText: t(locale, "contact.error"),
    networkErrorText: t(locale, "contact.networkError"),
  }}
>
  const form = document.getElementById("contact-form");
  const statusEl = document.getElementById("contact-status");
  const submitBtn = document.getElementById("contact-submit");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    if (!statusEl || !submitBtn) return;

    statusEl.textContent = sendingText;
    statusEl.className = "contact-status";
    submitBtn.setAttribute("disabled", "true");

    const formData = new FormData(form);
    formData.append("access_key", "YOUR_WEB3FORMS_KEY");

    const data = Object.fromEntries(formData);

    try {
      const response = await fetch("https://api.web3forms.com/submit", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Accept: "application/json",
        },
        body: JSON.stringify(data),
      });

      const result = await response.json();

      if (result.success) {
        statusEl.textContent = successText;
        statusEl.className = "contact-status success";
        form.reset();
      } else {
        statusEl.textContent = errorText;
        statusEl.className = "contact-status error";
      }
    } catch {
      statusEl.textContent = networkErrorText;
      statusEl.className = "contact-status error";
    } finally {
      submitBtn.removeAttribute("disabled");
      setTimeout(() => {
        statusEl.textContent = "";
        statusEl.className = "contact-status";
      }, 6000);
    }
  });
</script>
