    font-size: 13px;
    background: var(--pro-bg);
    border: 1px solid var(--pro-border);
    border-radius: 6px;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    
    // Understandable Real-world Demo Data: Internet Usage over time
    const demoData = [
      ["Country", "Year", "Internet Usage %", "GDP Rank", "Population", "Region", "Notes", "Status", "ID"],
      ["United States", "2010", 71, 1, "331M", "Americas", "-", "Active", "101"],
      ["United States", "2015", 74, 1, "331M", "Americas", "-", "Active", "102"],
      ["United States", "2023", 92, 1, "331M", "Americas", "Top", "Active", "103"],
      ["United Kingdom", "2010", 85, 6, "67M", "Europe", "-", "Active", "104"],
      ["United Kingdom", "2015", 92, 6, "67M", "Europe", "-", "Active", "105"],
      ["United Kingdom", "2023", 96, 6, "67M", "Europe", "High", "Active", "106"],
      ["Germany", "2010", 82, 4, "83M", "Europe", "-", "Active", "107"],
      ["Germany", "2015", 87, 4, "83M", "Europe", "-", "Active", "108"],
      ["Germany", "2023", 91, 4, "83M", "Europe", "-", "Active", "109"],
      ["Japan", "2010", 78, 3, "125M", "Asia", "-", "Active", "110"],
      ["Japan", "2015", 83, 3, "125M", "Asia", "-", "Active", "111"],
      ["Japan", "2023", 85, 3, "125M", "Asia", "-", "Active", "112"],
      ["Brazil", "2010", 40, 8, "214M", "Americas", "-", "Pending", "113"],
      ["Brazil", "2015", 58, 8, "214M", "Americas", "-", "Pending", "114"],
      ["Brazil", "2023", 81, 8, "214M", "Americas", "-", "Active", "115"],
      ["India", "2010", 8, 5, "1.4B", "Asia", "Low", "Pending", "116"],
      ["India", "2015", 27, 5, "1.4B", "Asia", "-", "Pending", "117"],
      ["India", "2023", 53, 5, "1.4B", "Asia", "Growing", "Active", "118"],
      ["China", "2010", 34, 2, "1.4B", "Asia", "-", "Pending", "119"],
      ["China", "2015", 50, 2, "1.4B", "Asia", "-", "Pending", "120"],
      ["China", "2023", 75, 2, "1.4B", "Asia", "Fast", "Active", "121"],
      ["South Africa", "2010", 24, 38, "60M", "Africa", "-", "Pending", "122"],
      ["South Africa", "2015", 51, 38, "60M", "Africa", "-", "Pending", "123"],
      ["South Africa", "2023", 72, 38, "60M", "Africa", "-", "Active", "124"],
      ["Mexico", "2010", 31, 14, "128M", "Americas", "-", "Pending", "125"],
      ["Mexico", "2015", 57, 14, "128M", "Americas", "-", "Pending", "126"],
      ["Mexico", "2023", 76, 14, "128M", "Americas", "-", "Active", "127"],
      ["Nigeria", "2010", 24, 31, "213M", "Africa", "Low", "Pending", "128"],
      ["Nigeria", "2015", 42, 31, "213M", "Africa", "-", "Pending", "129"],
      ["Nigeria", "2023", 55, 31, "213M", "Africa", "-", "Active", "130"]
    ];

    // Chart Options State
    let state = {
      showLegend: true,
      showGrid: true,
      showLabels: false
    };

    // Initialize ECharts with SVG renderer for scalable exports
    const chartDom = document.getElementById('chart-container');
    const myChart = window.echarts.init(chartDom, null, { renderer: 'svg' });

    // Initialize Spreadsheet
    const spreadsheet = jspreadsheet(document.getElementById('spreadsheet-container'), {
       data: demoData,
       columns: [
           { type: 'text', title: 'A', width: 90 },
           { type: 'text', title: 'B', width: 90 },
           { type: 'text', title: 'C', width: 90 },
           { type: 'text', title: 'D', width: 90 },
           { type: 'text', title: 'E', width: 90 },
           { type: 'text', title: 'F', width: 90 },
           { type: 'text', title: 'G', width: 90 },
           { type: 'text', title: 'H', width: 90 },
           { type: 'text', title: 'I', width: 90 }
       ],
       minDimensions: [9, 40],
       onchange: updateChart
    });

    const selCategory = document.getElementById('map-category');
    const selValue = document.getElementById('map-value');
    const selSeries = document.getElementById('map-series');
    const fmtColumn = document.getElementById('fmt-column');
    
    // Global States
    let currentChartType = 'scatter';
    let dataMode = 'rows';
    
    // Dataset Mode Toggles
    const chkHeadings = document.getElementById('chk-headings');
    const chkSeriesNames = document.getElementById('chk-series-names');
    const labelHeadings = document.getElementById('label-headings');

    // UI Wireups
    selCategory.addEventListener('change', updateChart);
    selValue.addEventListener('change', updateChart);
    selSeries.addEventListener('change', updateChart);
    chkHeadings.addEventListener('change', updateDropdowns);
    chkSeriesNames.addEventListener('change', updateChart);

    // Data Mode (Rows vs Columns)
    document.querySelectorAll('#toggle-data-mode .toggle-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        document.querySelectorAll('#toggle-data-mode .toggle-btn').forEach(b => b.classList.remove('active'));
        const targetBtn = e.currentTarget || e.target;
        targetBtn.classList.add('active');
        dataMode = targetBtn.getAttribute('data-mode');
        
        // Update labels text like Datylon
        if(dataMode === 'columns') {
          labelHeadings.innerText = 'First column are headings';
          document.getElementById('map-value').parentElement.style.opacity = '0.4';
          document.getElementById('map-series').parentElement.style.opacity = '0.4';
        } else {
          labelHeadings.innerText = 'First row are headings';
          document.getElementById('map-value').parentElement.style.opacity = '1';
          document.getElementById('map-series').parentElement.style.opacity = '1';
        }
        updateDropdowns();
      });
    });

    // --- Layout Actions (All Panels, View Data, View Styles, Only Preview) ---
    const layoutBtn = document.getElementById('btn-layout-mode');
    const layoutDropdown = document.getElementById('layout-dropdown');
    const layoutLabel = document.getElementById('layout-label');
    const gridContainer = document.querySelector('.pro-tool-grid');
    
    const selectChartBtn = document.getElementById('btn-select-chart');
    const selectChartDropdown = document.getElementById('dropdown-select-chart');

    // Toggle Layout Dropdown
    layoutBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      layoutDropdown.classList.toggle('show');
      selectChartDropdown.classList.remove('show');
    });
    
    // Toggle Select Chart Dropdown
    selectChartBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      selectChartDropdown.classList.toggle('show');
      layoutDropdown.classList.remove('show');
    });

    // Close dropdowns on outside click
    document.addEventListener('click', () => {
      layoutDropdown.classList.remove('show');
      selectChartDropdown.classList.remove('show');
    });

    // Chart Type Selector
    document.querySelectorAll('#dropdown-select-chart .dropdown-item').forEach(item => {
      item.addEventListener('click', (e) => {
        document.querySelectorAll('#dropdown-select-chart .dropdown-item').forEach(i => i.classList.remove('active'));
        e.currentTarget.classList.add('active');
        currentChartType = e.currentTarget.getAttribute('data-chart');
        
        // Update Chart Title Header Label with Branding
        document.querySelector('.chart-title-lbl').innerHTML = `${e.currentTarget.innerText} <span style="color: #00c896;">Maker&reg;</span>`;
        updateChart();
      });
    });

    document.querySelectorAll('#layout-dropdown .dropdown-item').forEach(item => {
      item.addEventListener('click', (e) => {
        document.querySelectorAll('.dropdown-item').forEach(i => i.classList.remove('active'));
        const targetBtn = e.currentTarget || e.target;
        targetBtn.classList.add('active');
        
        const mode = targetBtn.getAttribute('data-layout');
        layoutLabel.innerText = targetBtn.querySelector('span').innerText;
        
        // Remove all layout classes
        gridContainer.classList.remove('layout-all', 'layout-styles', 'layout-data', 'layout-preview');
        
        if (mode !== 'all') {
          gridContainer.classList.add(`layout-${mode}`);
        }
        
        // Force chart to resize after panel animations complete
        setTimeout(() => { myChart.resize(); }, 300);
      });
    });
    
    // --- Zoom Controls ---
    let currentZoom = 1.0;
    const chartWrapper = document.getElementById('chart-wrapper');
    const zoomSelect = document.getElementById('zoom-select');
    
    const applyZoom = () => {
      // Boundaries
      if (currentZoom < 0.25) currentZoom = 0.25;
      if (currentZoom > 3.0) currentZoom = 3.0;
      
      chartWrapper.style.transform = `scale(${currentZoom})`;
      
      // Attempt to map to standard option if exact match, otherwise leave custom
      const standardVals = ["50", "75", "100", "125", "150", "200"];
      const percentage = Math.round(currentZoom * 100).toString();
      if(standardVals.includes(percentage)){
         zoomSelect.value = percentage;
      }
    };
    
    document.getElementById('btn-zoom-in').addEventListener('click', () => {
      currentZoom += 0.25; applyZoom();
    });
    document.getElementById('btn-zoom-out').addEventListener('click', () => {
      currentZoom -= 0.25; applyZoom();
    });
    document.getElementById('btn-zoom-fit').addEventListener('click', () => {
      currentZoom = 1.0; applyZoom();
    });
    zoomSelect.addEventListener('change', (e) => {
      currentZoom = parseInt(e.target.value) / 100;
      applyZoom();
    });

    // Tab Logic
    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
        e.target.classList.add('active');
        const target = e.target.getAttribute('data-target');
        document.getElementById(target).classList.add('active');
      });
    });

    // Accordion Logic
    document.querySelectorAll('.accordion-header').forEach(header => {
      header.addEventListener('click', (e) => {
        // Prevent toggle if clicking an inner icon
        if((e.target as Element).closest('.icon-btn')) return;
        
        const content = header.nextElementSibling;
        if(content && content.classList.contains('accordion-content')) {
          content.classList.toggle('open');
          const chevron = header.querySelector('.chevron');
          if(chevron) {
              (chevron as HTMLElement).style.transform = content.classList.contains('open') ? 'rotate(90deg)' : 'rotate(0deg)';
          }
        }
      });
    });

    // Button Toggle Logic
    document.querySelectorAll('.toggle-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        if(btn.classList.contains('disabled')) return;
        const parent = btn.parentElement;
        if(parent) {
            parent.querySelectorAll('.toggle-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
        }
      });
    });

    // Styling Toggles
    const toggleLegend = document.getElementById('toggle-legend');
    const toggleGrid = document.getElementById('toggle-grid');
    const toggleLabels = document.getElementById('toggle-labels');

    const updateToggle = (btn, key) => {
       state[key] = !state[key];
       if(state[key]) {
         btn.classList.add('active');
         btn.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>`;
       } else {
         btn.classList.remove('active');
         btn.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg>`;
       }
       updateChart();
    };

    toggleLegend.addEventListener('click', (e) => { e.stopPropagation(); updateToggle(toggleLegend, 'showLegend'); });
    toggleGrid.addEventListener('click', (e) => { e.stopPropagation(); updateToggle(toggleGrid, 'showGrid'); });
    toggleLabels.addEventListener('click', (e) => { e.stopPropagation(); updateToggle(toggleLabels, 'showLabels'); });


    function getGridData() {
        return spreadsheet.getData();
    }

    function updateDropdowns() {
        const data = getGridData();
        if(!data || data.length === 0) return;

        let headers = [];
        const hasHeaders = chkHeadings.checked;
        
        if (hasHeaders) {
            headers = data[0].slice(0, 3);
        } else {
            headers = ["Col A", "Col B", "Col C"];
        }

        const makeOptions = (selectedIdx) => {
            return headers.map((h, i) => `<option value="${i}" ${i == selectedIdx ? 'selected' : ''}>${h}</option>`).join('');
        };
        
        // Extended placeholder formatting options strictly matching image requests
        const extraFormattingCols = ["column D", "column E", "column F", "column G", "column H", "column I"];
        const formattingOptions = headers.map((h, i) => `<option value="${i}">${h}</option>`)
          .concat(extraFormattingCols.map((col, i) => `<option value="ext-${i}">${col}</option>`))
          .join('');

        const curCat = selCategory.value !== "" ? selCategory.value : 0;
        const curSer = selSeries.value !== "" ? selSeries.value : 1;
        const curVal = selValue.value !== "" ? selValue.value : 2;

        selCategory.innerHTML = makeOptions(curCat);
        selSeries.innerHTML = makeOptions(curSer);
        selValue.innerHTML = makeOptions(curVal);
        fmtColumn.innerHTML = `<option>Select column...</option>` + formattingOptions;

        updateChart();
    }

    function updateChart() {
        const data = getGridData();
        if(!data || data.length < 2) return;

        const seriesMap = new Map();
        const categoriesSet = new Set();
        const colorPalette = { "2010": "#f53838", "2015": "#ffd60a", "2023": "#1761f2" };
        const fallbackColors = [ '#ff4d4f', '#ffc53d', '#1890ff', '#52c41a', '#722ed1', '#13c2c2', '#eb2f96'];
        
        const hasHeadings = chkHeadings.checked;
        const useHeadingsAsSeries = chkSeriesNames.checked;
        const catIdx = parseInt(selCategory.value || 0);

        // --- LONG FORMAT (Rows) ---
        if (dataMode === 'rows') {
            const startIndex = hasHeadings ? 1 : 0;
            const valIdx = parseInt(selValue.value || 2);
            const serIdx = parseInt(selSeries.value || 1);

            for(let i = startIndex; i < data.length; i++) {
                const row = data[i];
                if (!row) continue;
                const cat = row[catIdx];
                const val = parseFloat(row[valIdx]);
                const ser = row[serIdx] || "Series 1";

                if (cat === "" || cat == null || isNaN(val)) continue;

                categoriesSet.add(cat);
                if(!seriesMap.has(ser)) seriesMap.set(ser, []);
                seriesMap.get(ser).push([val, String(cat)]);
            }
        } 
        // --- WIDE FORMAT (Columns) ---
        else {
            // First column are headings = check column 0 logic? Wait, the label changes to 
            // 'First column are headings', meaning the first column contains the categories!
            // 'Headings are series names' means Row 0 contains series names.
            
            const startRowIdx = useHeadingsAsSeries ? 1 : 0;
            const startColIdx = hasHeadings ? 1 : 0; // If first column is headings, values start at col 1

            // The list of series is mapped to the columns (Col 1, Col 2, etc, ignoring catIdx)
            let seriesNames = [];
            const headerRow = data[0];
            
            const maxCols = data.reduce((max, row) => Math.max(max, row.length), 0);
            
            for(let c = startColIdx; c < maxCols; c++) {
              if (c === catIdx) continue; // Skip the category column
              const sName = useHeadingsAsSeries && headerRow[c] ? headerRow[c] : `Series ${c}`;
              seriesNames.push({ colIndex: c, name: sName });
              seriesMap.set(sName, []);
            }

            for(let r = startRowIdx; r < data.length; r++) {
                const row = data[r];
                if (!row) continue;
                const cat = row[catIdx];
                if (cat === "" || cat == null) continue;
                
                let hasValidVal = false;
                seriesNames.forEach(s => {
                    const val = parseFloat(row[s.colIndex]);
                    if (!isNaN(val)) {
                      seriesMap.get(s.name).push([val, String(cat)]);
                      hasValidVal = true;
                    }
                });
                
                if (hasValidVal) {
                  categoriesSet.add(cat);
                }
            }
        }

        // Exact Y-axis order
        const categories = Array.from(categoriesSet).sort((a,b) => String(a).localeCompare(String(b))).reverse();

        const series = [];
        let colorIdx = 0;

        for(let [serName, points] of seriesMap.entries()){
            if (points.length === 0) continue;
            
            const c = colorPalette[serName] || fallbackColors[colorIdx % fallbackColors.length];
            series.push({
                name: serName,
                type: currentChartType,
                symbolSize: 12,
                barMaxWidth: 24,
                smooth: true,
                data: points,
                itemStyle: { color: c },
                label: { 
                  show: state.showLabels, 
                  position: 'top', 
                  formatter: '{@[0]}',
                  fontSize: 10,
                  color: '#a1b0bd'
                },
                z: 3
            });
            colorIdx++;
        }

        // Range Lines Background processing (only for dot plots)
        if (currentChartType === 'scatter') {
          const lineData = [];
          if (dataMode === 'rows') {
            const valIdx = parseInt(selValue.value || 2);
            categories.forEach((cat, index) => {
                let vals = [];
                const startIndex = hasHeadings ? 1 : 0;
                for(let i=startIndex; i<data.length; i++){
                    if(data[i][catIdx] === cat && !isNaN(parseFloat(data[i][valIdx]))) {
                        vals.push(parseFloat(data[i][valIdx]));
                    }
                }
                if(vals.length > 1) {
                   vals.sort((a,b) => a - b);
                   lineData.push([{ coord: [vals[0], index] }, { coord: [vals[vals.length-1], index] }]);
                }
            });
        } else {
            // Range logic for wide format
            const startRowIdx = useHeadingsAsSeries ? 1 : 0;
            const startColIdx = hasHeadings ? 1 : 0;
            const maxCols = data.reduce((max, row) => Math.max(max, row.length), 0);
            
            categories.forEach((cat, index) => {
                let vals = [];
                for(let r=startRowIdx; r<data.length; r++){
                   if(data[r][catIdx] === cat) {
                       for(let c = startColIdx; c < maxCols; c++) {
                           if (c === catIdx) continue;
                           const val = parseFloat(data[r][c]);
                           if (!isNaN(val)) vals.push(val);
                       }
                   }
                }
                if(vals.length > 1) {
                   vals.sort((a,b) => a - b);
                   lineData.push([{ coord: [vals[0], index] }, { coord: [vals[vals.length-1], index] }]);
                }
            });
          }

          series.push({
              type: 'lines',
              polyline: false,
              z: 1,
              lineStyle: {
                  color: '#3a4a5c',
                  width: 1,
                  type: 'solid'
              },
              data: lineData
          });
        }

        const option = {
            backgroundColor: 'transparent',
            animation: false,
            tooltip: {
                trigger: 'item',
                formatter: function (p) {
                    if(p.seriesType === 'lines') return '';
                    return `<b>${p.seriesName}</b><br/>${p.value[1]}: ${p.value[0]}`;
                }
            },
            legend: {
                show: state.showLegend,
                top: 10,
                right: 30,
                icon: 'circle',
                textStyle: { color: '#a1b0bd' }
            },
            grid: {
                left: '8%',
                right: '5%',
                bottom: '10%',
                top: '15%',
                containLabel: true
            },
            xAxis: {
                type: 'value',
                min: 0,
                max: 100,
                interval: 20,
                splitLine: {
                    show: state.showGrid,
                    lineStyle: { color: '#243040' }
                },
                axisLine: { show: false },
                axisTick: { show: false },
                axisLabel: { color: '#a1b0bd', fontSize: 11 }
            },
            yAxis: {
                type: 'category',
                data: categories,
                axisLine: { show: false },
                axisTick: { show: false },
                splitLine: { show: false },
                axisLabel: { color: '#a1b0bd', fontSize: 11 }
            },
            series: series
        };

        myChart.setOption(option, true);
    }

    setTimeout(() => {
        updateDropdowns();
        window.addEventListener('resize', () => { myChart.resize(); });
    }, 100);

    // Export Handlers
    document.getElementById('btn-export-png')?.addEventListener('click', () => {
        const url = myChart.getDataURL({ type: 'png', pixelRatio: 2, backgroundColor: '#151d26' });
        const a = document.createElement('a');
        a.download = 'cleveland-dot-plot.png';
        a.href = url;
        a.click();
    });

    document.getElementById('btn-export-svg')?.addEventListener('click', () => {
        const url = myChart.getDataURL({ type: 'svg', backgroundColor: '#fff' });
        const a = document.createElement('a');
        a.download = 'cleveland-dot-plot.svg';
        a.href = url;
        a.click();
    });

    // File Upload Handler (CSV / XLSX)
    document.getElementById('file-upload')?.addEventListener('change', function(e) {
        const file = (e.target as HTMLInputElement).files?.[0];
        if(!file) return;

        const reader = new FileReader();
        reader.onload = function(evt) {
            try {
                const data = evt.target?.result;
                if(!data) return;
                
                // Parse using SheetJS
                const workbook = window.XLSX.read(data, {type: 'binary'});
                const firstSheetName = workbook.SheetNames[0];
                const worksheet = workbook.Sheets[firstSheetName];
                
                // Convert to array of arrays
                const excelData = window.XLSX.utils.sheet_to_json(worksheet, {header: 1, defval: ""});
                
                if(excelData && excelData.length > 0) {
                    spreadsheet.setData(excelData);
                    setTimeout(updateDropdowns, 100);
                }
            } catch (err) {
                console.error("Error parsing file:", err);
                alert("Could not parse file. Please ensure it is a valid CSV or Excel file.");
            }
            // Reset input
            (e.target as HTMLInputElement).value = "";
        };
        reader.readAsBinaryString(file);
    });
  });
</script>
