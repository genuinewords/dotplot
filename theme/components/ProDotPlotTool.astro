  }
  .accordion.alt {
    border: 1px solid var(--pro-border);
    background: var(--pro-bg);
    margin: 0 0 0.5rem 0;
    border-radius: 6px;
    box-shadow: 0 1px 2px rgba(0,0,0,0.15);
  }
  .accordion-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.85rem 0.5rem;
    margin: 0 -0.5rem;
    border-radius: 4px;
    cursor: pointer;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-dark);
    transition: background 0.2s;
  }
  .accordion-header:hover { background: rgba(255,255,255,0.04); }
  .accordion-content {
    display: none;
    padding-bottom: 1rem;
  }
  .accordion-content.open { display: block; }
  .chevron { transition: transform 0.2s ease; }
  .placeholder-text { font-size: 12px; color: var(--text-light); padding: 0.5rem 0; margin: 0; }
  
  .right-icons {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .icon-btn {
    background: none;
    border: none;
    color: var(--text-light);
    cursor: pointer;
    padding: 2px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .icon-btn.active { color: var(--text-dark); }
  
  /* Inputs & Selects */
  .mapping-group { margin-bottom: 1.2rem; }
  .mapping-group label {
    display: block;
    font-size: 12px;
    font-weight: 500;
    color: var(--text-gray);
    margin-bottom: 0.4rem;
  }
  .form-input, .form-select {
    width: 100%;
    padding: 0.6rem 0.75rem;
    border-radius: 6px;
    border: 1px solid var(--pro-border);
    font-size: 13px;
    color: var(--text-dark);
    outline: none;
    background: var(--pro-bg);
    transition: all 0.2s ease;
    box-shadow: 0 1px 2px rgba(0,0,0,0.15);
  }
  .form-select {
    cursor: pointer;
    appearance: none;
    background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="%23a1b0bd" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>');
    background-repeat: no-repeat;
    background-position: right 10px center;
    padding-right: 32px;
  }
  .form-select:hover, .form-input:hover { border-color: #3a4a5c; }
  .form-select:focus, .form-input:focus {
    border-color: var(--accent-blue);
    box-shadow: 0 0 0 3px rgba(0,212,170,0.15);
  }
