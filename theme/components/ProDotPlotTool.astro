  /* Custom Checkbox */
  .custom-checkbox {
    display: flex; align-items: center; justify-content: space-between;
    cursor: pointer; padding: 6px 0; margin-bottom: 0.5rem;
  }
  .custom-checkbox span { font-size: 13px; font-weight: 500; color: var(--text-dark); }
  .custom-checkbox input { display: none; }
  .chk-box {
    width: 18px; height: 18px; border: 2px solid #b0b6c2; border-radius: 4px;
    display: flex; align-items: center; justify-content: center; transition: all 0.2s;
    background: var(--pro-panel);
  }
  .chk-box svg { width: 12px; height: 12px; stroke: white; stroke-width: 3; fill: none; stroke-linecap: round; stroke-linejoin: round; opacity: 0; }
  .custom-checkbox:hover .chk-box { border-color: var(--text-gray); }
  .custom-checkbox input:checked + .chk-box { background: var(--accent-blue); border-color: var(--accent-blue); }
  .custom-checkbox input:checked + .chk-box svg { opacity: 1; }
  
  /* Segmented Toggles */
  .toggle-group {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .toggle-buttons {
    display: flex;
    background: var(--pro-bg);
    border-radius: 6px;
    padding: 3px;
    gap: 2px;
  }
  .toggle-btn {
    padding: 6px 16px;
    font-size: 12px;
    font-weight: 500;
    border: none;
    background: transparent;
    border-radius: 4px;
    color: var(--text-gray);
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .toggle-btn:hover:not(.disabled):not(.active) { color: var(--text-dark); }
  .toggle-btn.active {
    background: var(--accent-blue);
    color: #fff;
    box-shadow: 0 1px 6px rgba(0,212,170,0.25);
  }
  .toggle-btn.disabled { opacity: 0.5; pointer-events: none; }

  .accordion {
    border-top: 1px solid var(--pro-border);
    margin: 0 -1.25rem;
