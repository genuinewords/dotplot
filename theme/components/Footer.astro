---
import { type Locale, defaultLocale } from "@src/i18n/config";
import { t, getLocaleHomeUrl } from "@src/i18n/utils";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import siteConfig from "@src/config/site.json";

interface Props {
  locale?: Locale;
}

const { locale = defaultLocale } = Astro.props;
const homeUrl = getLocaleHomeUrl(locale);
const currentYear = new Date().getFullYear();
const hasSocials = Object.values(siteConfig.social).some(Boolean);
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <!-- Brand Column -->
      <div class="footer-brand-col">
        <a href={homeUrl} class="footer-brand">
          <svg class="footer-logo" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" width="28" height="28" aria-hidden="true">
            <defs>
              <linearGradient id="ftr-bg" x1="0" y1="0" x2="32" y2="32" gradientUnits="userSpaceOnUse">
                <stop offset="0%" stop-color="#0d1117"/>
                <stop offset="100%" stop-color="#0a0f14"/>
              </linearGradient>
            </defs>
            <rect width="32" height="32" rx="7" fill="url(#ftr-bg)"/>
            <circle cx="9" cy="8" r="2.4" fill="#00d4aa"/>
            <circle cx="9" cy="16" r="2.4" fill="#00d4aa" opacity="0.7"/>
            <circle cx="9" cy="24" r="2.4" fill="#00d4aa" opacity="0.45"/>
            <circle cx="16.5" cy="12" r="2.4" fill="#6d5cf6" opacity="0.85"/>
            <circle cx="16.5" cy="20" r="2.4" fill="#8b5cf6"/>
            <circle cx="24" cy="8" r="2.4" fill="#8b5cf6" opacity="0.5"/>
            <circle cx="24" cy="16" r="2.4" fill="#00d4aa" opacity="0.6"/>
            <circle cx="24" cy="24" r="2.4" fill="#00d4aa"/>
          </svg>
          <span>{t(locale, "site.title")}</span>
        </a>
        <p class="footer-desc">{t(locale, "footer.description")}</p>
        {hasSocials && (
          <div class="footer-social">
            {siteConfig.social.facebook && (
              <a href={siteConfig.social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="social-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              </a>
            )}
            {siteConfig.social.twitter && (
              <a href={siteConfig.social.twitter} target="_blank" rel="noopener noreferrer" aria-label="Twitter" class="social-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              </a>
            )}
            {siteConfig.social.linkedin && (
              <a href={siteConfig.social.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="social-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
            )}
            {siteConfig.social.pinterest && (
              <a href={siteConfig.social.pinterest} target="_blank" rel="noopener noreferrer" aria-label="Pinterest" class="social-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738.098.119.112.224.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12.017 24c6.624 0 11.99-5.367 11.99-11.988C24.007 5.367 18.641 0 12.017 0z"/></svg>
              </a>
            )}
          </div>
        )}
      </div>

      <!-- Nav Column -->
      <div class="footer-nav-col">
        <p class="footer-heading">{t(locale, "nav.home")}</p>
        <nav class="footer-nav" aria-label="Footer navigation">
          {siteConfig.footerNav.map((item: any) => (
            <a href={item.href} class="footer-link">{t(locale, item.label)}</a>
          ))}
        </nav>
      </div>

      <!-- Language Column -->
      <div class="footer-lang-col">
        <p class="footer-heading">{t(locale, "common.switchLanguage")}</p>
        <LanguageSwitcher locale={locale} />
      </div>
    </div>

    <!-- Copyright -->
    <div class="footer-bottom">
      <p>&copy; {currentYear} {siteConfig.siteName}. {t(locale, "footer.copyright")}</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    z-index: 1;
    border-top: 1px solid var(--color-border);
    padding: 4rem 0 2rem;
    margin-top: 4rem;
    background: rgba(10, 10, 26, 0.6);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }
  .footer-brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--color-text-primary);
    font-weight: 700;
    font-size: 1.05rem;
    margin-bottom: 1rem;
  }
  .footer-brand:hover { color: var(--color-primary); }
  .footer-desc {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.7;
    max-width: 360px;
    margin-bottom: 1rem;
  }
  .footer-logo {
    border-radius: 8px;
    border: 1px solid var(--color-border);
  }
  .footer-heading {
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }
  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .footer-link {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .footer-link:hover { color: var(--color-primary); }
  .footer-social {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }
  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    transition: all 0.2s ease;
  }
  .social-icon:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
    background: rgba(0, 212, 170, 0.08);
    transform: translateY(-2px);
  }
  .footer-bottom {
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }
  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
