---
import { type Locale, defaultLocale } from "@src/i18n/config";

interface Props {
  locale?: Locale;
}

const { locale = defaultLocale } = Astro.props;
---

<section id="pro-dot-plot-tool" class="dotplot-wrapper">
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
  
  <style is:inline>
    .dotplot-wrapper {
      --bg: #0a0f14;
      --bg-elevated: #111920;
      --fg: #e8eef4;
      --muted: #6b7d8f;
      --accent: #00d4aa;
      --accent-dim: rgba(0, 212, 170, 0.15);
      --card: #151d26;
      --border: #243040;
      --danger: #ff6b6b;
      
      font-family: 'Space Grotesk', sans-serif;
      background: var(--bg);
      color: var(--fg);
      position: relative;
      overflow: hidden;
      border-radius: 16px;
      margin: 3rem auto;
      max-width: 1200px;
      padding: 2.5rem;
      box-shadow: 0 30px 60px -12px rgba(0, 212, 170, 0.15), 0 0 0 1px rgba(255,255,255,0.1);
    }

    .dotplot-wrapper * {
      box-sizing: border-box;
    }

    .dotplot-wrapper .font-mono {
      font-family: 'IBM Plex Mono', monospace;
    }

    /* Background atmosphere */
    .dotplot-wrapper .bg-atmosphere {
      position: absolute;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      background: 
        radial-gradient(ellipse 80% 50% at 20% 10%, rgba(0, 212, 170, 0.08) 0%, transparent 50%),
        radial-gradient(ellipse 60% 40% at 80% 90%, rgba(0, 150, 136, 0.06) 0%, transparent 50%),
        linear-gradient(180deg, var(--bg) 0%, #0d1318 100%);
    }

    .dotplot-wrapper .grid-pattern {
      position: absolute;
      inset: 0;
      pointer-events: none;
      z-index: 1;
      opacity: 0.03;
      background-image: 
        linear-gradient(var(--muted) 1px, transparent 1px),
        linear-gradient(90deg, var(--muted) 1px, transparent 1px);
      background-size: 40px 40px;
    }

    /* Entrance animations */
    @keyframes fadeSlideUp {
      from { opacity: 0; transform: translateY(30px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .dotplot-wrapper .animate-entrance {
      animation: fadeSlideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      opacity: 0;
    }

    .dotplot-wrapper .delay-1 { animation-delay: 0.1s; }
    .dotplot-wrapper .delay-2 { animation-delay: 0.2s; }
    .dotplot-wrapper .delay-3 { animation-delay: 0.3s; }
    .dotplot-wrapper .delay-4 { animation-delay: 0.4s; }
    .dotplot-wrapper .delay-5 { animation-delay: 0.5s; }

    @media (prefers-reduced-motion: reduce) {
      .dotplot-wrapper .animate-entrance { animation: none; opacity: 1; }
    }

    /* Custom scrollbar */
    .dotplot-wrapper ::-webkit-scrollbar { width: 8px; height: 8px; }
    .dotplot-wrapper ::-webkit-scrollbar-track { background: var(--bg-elevated); }
    .dotplot-wrapper ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }
    .dotplot-wrapper ::-webkit-scrollbar-thumb:hover { background: var(--muted); }

    /* Focus states */
    .dotplot-wrapper *:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }

    /* Input styles */
    .dotplot-wrapper .input-field {
      background: var(--bg);
      border: 1px solid var(--border);
      color: var(--fg);
      padding: 0.75rem 1rem;
      border-radius: 8px;
      transition: all 0.2s ease;
      width: 100%;
    }
    .dotplot-wrapper .input-field:hover { border-color: var(--muted); }
    .dotplot-wrapper .input-field:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px var(--accent-dim);
    }

    /* Button styles */
    .dotplot-wrapper .btn-primary {
      background: var(--accent);
      color: var(--bg);
      font-weight: 600;
      padding: 0.75rem 1.5rem;
      border-radius: 8px;
      transition: all 0.2s ease;
      border: none;
      cursor: pointer;
    }
    .dotplot-wrapper .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(0, 212, 170, 0.3);
    }
    .dotplot-wrapper .btn-primary:active { transform: translateY(0); }

    .dotplot-wrapper .btn-secondary {
      background: transparent;
      color: var(--fg);
      font-weight: 500;
      padding: 0.75rem 1.5rem;
      border-radius: 8px;
      transition: all 0.2s ease;
      border: 1px solid var(--border);
      cursor: pointer;
    }
    .dotplot-wrapper .btn-secondary:hover {
      border-color: var(--muted);
      background: var(--card);
    }

    /* Card styles */
    .dotplot-wrapper .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.5rem;
    }

    /* Canvas container */
    .dotplot-wrapper .canvas-container {
      background: var(--bg-elevated);
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
      position: relative;
    }

    /* Range input */
    .dotplot-wrapper input[type="range"] {
      -webkit-appearance: none;
      appearance: none;
      background: var(--border);
      height: 4px;
      border-radius: 2px;
      cursor: pointer;
    }
    .dotplot-wrapper input[type="range"]::-webkit-slider-thumb {
      -webkit-appearance: none;
      width: 18px;
      height: 18px;
      background: var(--accent);
      border-radius: 50%;
      cursor: pointer;
      transition: transform 0.2s ease;
    }
    .dotplot-wrapper input[type="range"]::-webkit-slider-thumb:hover { transform: scale(1.2); }

    /* Color picker wrapper */
    .dotplot-wrapper .color-picker-wrapper {
      position: relative;
      width: 48px;
      height: 48px;
      border-radius: 8px;
      overflow: hidden;
      border: 2px solid var(--border);
      cursor: pointer;
      transition: border-color 0.2s ease;
    }
    .dotplot-wrapper .color-picker-wrapper:hover { border-color: var(--muted); }
    .dotplot-wrapper .color-picker-wrapper input {
      position: absolute;
      inset: -4px;
      width: calc(100% + 8px);
      height: calc(100% + 8px);
      cursor: pointer;
      border: none;
    }

    /* Tooltip animation */
    .dotplot-wrapper .tooltip {
      position: absolute;
      background: var(--card);
      border: 1px solid var(--border);
      padding: 0.5rem 0.75rem;
      border-radius: 6px;
      font-size: 0.75rem;
      pointer-events: none;
      opacity: 0;
      transform: translateY(5px);
      transition: all 0.2s ease;
      white-space: nowrap;
      z-index: 100;
    }
    .dotplot-wrapper .tooltip.visible { opacity: 1; transform: translateY(0); }

    /* Data badge */
    .dotplot-wrapper .data-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.25rem;
      background: var(--accent-dim);
      color: var(--accent);
      padding: 0.25rem 0.5rem;
      border-radius: 4px;
      font-size: 0.75rem;
      font-weight: 500;
    }

    /* Tab styles */
    .dotplot-wrapper .tab-btn {
      padding: 0.5rem 1rem;
      border-radius: 6px;
      font-weight: 500;
      color: var(--muted);
      background: transparent;
      border: none;
      cursor: pointer;
      transition: all 0.2s ease;
    }
    .dotplot-wrapper .tab-btn:hover { color: var(--fg); }
    .dotplot-wrapper .tab-btn.active { background: var(--accent-dim); color: var(--accent); }
  </style>

  <div class="bg-atmosphere"></div>
  <div class="grid-pattern"></div>

  <div class="relative z-10 w-full max-w-7xl mx-auto">
    <!-- Header/Logo inline for the component -->
    <div class="animate-entrance flex flex-col sm:flex-row items-center sm:items-start justify-between mb-8 gap-4">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-[10px] bg-[#00d4aa] flex items-center justify-center">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#0a0f14" stroke-width="3">
            <circle cx="12" cy="11" r="1.5"/>
            <circle cx="9" cy="14" r="1.5"/>
            <circle cx="9" cy="18" r="1.5"/>
            <circle cx="14" cy="16" r="1.5"/>
            <circle cx="17" cy="18" r="1.5"/>
          </svg>
        </div>
        <span class="text-xl font-bold tracking-tight">Dot Plot Maker®</span>
      </div>
      <div class="text-right text-sm" style="color: var(--muted);">
        Interactive Environment
      </div>
    </div>

    <!-- Main Grid -->
    <div class="grid lg:grid-cols-3 gap-6">
      
      <!-- Left Panel: Data Input -->
      <div class="lg:col-span-1 space-y-6">
        
        <!-- Data Input Card -->
        <div class="card animate-entrance delay-3 text-left">
          <div class="flex items-center justify-between mb-4">
            <h2 class="font-semibold" style="color: var(--fg);">Data Input</h2>
            <div class="flex gap-1">
              <button class="tab-btn active" data-tab="manual" onclick="switchDotplotTab('manual')">Manual</button>
              <button class="tab-btn" data-tab="paste" onclick="switchDotplotTab('paste')">Paste</button>
            </div>
          </div>
          
          <div id="manual-tab">
            <div class="space-y-3">
              <div>
                <label class="block text-sm mb-2" style="color: var(--muted);">Data values (comma separated)</label>
                <input 
                  type="text" 
                  id="data-input"
                  class="input-field font-mono text-sm"
                  placeholder="3, 5, 7, 4, 5, 6, 3, 8... "
                  value="12, 15, 18, 12, 14, 16, 18, 20, 15, 13"
                >
              </div>
              <div>
                <label class="block text-sm mb-2" style="color: var(--muted);">Label (optional)</label>
                <input 
                  type="text" 
                  id="label-input"
                  class="input-field text-sm"
                  placeholder="Dataset name"
                  value="Sample Dataset"
                >
              </div>
              <button onclick="addDataset()" class="btn-primary w-full flex items-center justify-center gap-2">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="12" y1="5" x2="12" y2="19"></line>
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                </svg>
                Add Dataset
              </button>
            </div>
          </div>
          
          <div id="paste-tab" class="hidden">
            <div>
              <label class="block text-sm mb-2" style="color: var(--muted);">Paste your data (CSV or space-separated)</label>
              <textarea 
                id="paste-input"
                class="input-field font-mono text-sm resize-none"
                rows="6"
                placeholder="12, 15, 18, 12, 14&#10;16, 18, 20, 15, 13&#10;14, 16, 17, 15, 14"
              ></textarea>
              <button onclick="parsePasteData()" class="btn-primary w-full mt-3">Import Data</button>
            </div>
          </div>
        </div>

        <!-- Datasets List -->
        <div class="card animate-entrance delay-4 text-left">
          <h2 class="font-semibold mb-4" style="color: var(--fg);">Active Datasets</h2>
          <div id="datasets-list" class="space-y-2">
            <!-- Datasets will be rendered here -->
          </div>
        </div>

        <!-- Style Controls -->
        <div class="card animate-entrance delay-5 text-left">
          <h2 class="font-semibold mb-4" style="color: var(--fg);">Style Options</h2>
          
          <div class="space-y-4">
            <div>
              <label class="block text-sm mb-2 flex justify-between" style="color: var(--muted);">
                <span>Dot Size</span>
                <span id="dot-size-value" class="font-mono" style="color: var(--accent);">10</span>
              </label>
              <input type="range" id="dot-size" min="4" max="24" value="10" class="w-full" oninput="updatePlot()">
            </div>
            
            <div>
              <label class="block text-sm mb-2 flex justify-between" style="color: var(--muted);">
                <span>Dot Opacity</span>
                <span id="dot-opacity-value" class="font-mono" style="color: var(--accent);">0.8</span>
              </label>
              <input type="range" id="dot-opacity" min="0.3" max="1" step="0.1" value="0.8" class="w-full" oninput="updatePlot()">
            </div>
            
            <div>
              <label class="block text-sm mb-2" style="color: var(--muted);">Primary Color</label>
              <div class="flex items-center gap-3">
                <div class="color-picker-wrapper">
                  <input type="color" id="color-picker" value="#00d4aa" onchange="updatePlot()">
                </div>
                <span id="color-hex" class="font-mono text-sm" style="color: var(--muted);">#00d4aa</span>
              </div>
            </div>

            <div class="flex items-center justify-between pt-2">
              <label class="text-sm" style="color: var(--muted);">Show Grid</label>
              <button 
                id="grid-toggle" 
                class="w-12 h-6 rounded-full transition-colors duration-200"
                style="background: var(--accent);"
                onclick="toggleAdvancedGrid()"
                aria-label="Toggle grid"
              >
                <div class="w-5 h-5 rounded-full bg-white transform translate-x-6 transition-transform duration-200"></div>
              </button>
            </div>

            <div class="flex items-center justify-between">
              <label class="text-sm" style="color: var(--muted);">Stack Duplicates</label>
              <button 
                id="stack-toggle" 
                class="w-12 h-6 rounded-full transition-colors duration-200"
                style="background: var(--accent);"
                onclick="toggleAdvancedStack()"
                aria-label="Toggle stacking"
              >
                <div class="w-5 h-5 rounded-full bg-white transform translate-x-6 transition-transform duration-200"></div>
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Panel: Visualization -->
      <div class="lg:col-span-2 space-y-6">
        
        <!-- Canvas -->
        <div class="canvas-container animate-entrance delay-4" style="min-height: 480px;">
          <div class="absolute top-4 right-4 z-10 flex gap-2">
            <button onclick="exportSVG()" class="btn-secondary text-sm flex items-center gap-2" aria-label="Export as SVG">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              SVG
            </button>
            <button onclick="exportPNG()" class="btn-primary text-sm flex items-center gap-2" aria-label="Export as PNG">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                <circle cx="8.5" cy="8.5" r="1.5"></circle>
                <polyline points="21 15 16 10 5 21"></polyline>
              </svg>
              PNG
            </button>
          </div>
          <!-- Keep specific inline block display without conflicting layout issues -->
          <canvas id="dot-plot-canvas" style="display: block; width: 100%;"></canvas>
          <div id="tooltip" class="tooltip text-left"></div>
        </div>

        <!-- Statistics Panel -->
        <div class="grid sm:grid-cols-4 gap-4 animate-entrance delay-5">
          <div class="card text-center">
            <div class="text-sm mb-1" style="color: var(--muted);">Data Points</div>
            <div id="stat-count" class="text-2xl font-bold font-mono" style="color: var(--accent);">0</div>
          </div>
          <div class="card text-center">
            <div class="text-sm mb-1" style="color: var(--muted);">Mean</div>
            <div id="stat-mean" class="text-2xl font-bold font-mono" style="color: var(--fg);">0</div>
          </div>
          <div class="card text-center">
            <div class="text-sm mb-1" style="color: var(--muted);">Median</div>
            <div id="stat-median" class="text-2xl font-bold font-mono" style="color: var(--fg);">0</div>
          </div>
          <div class="card text-center">
            <div class="text-sm mb-1" style="color: var(--muted);">Std Dev</div>
            <div id="stat-std" class="text-2xl font-bold font-mono" style="color: var(--fg);">0</div>
          </div>
        </div>

        <!-- Data Preview -->
        <div class="card animate-entrance delay-5 text-left">
          <h2 class="font-semibold mb-4" style="color: var(--fg);">Data Frequency Table</h2>
          <div id="frequency-table" class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr style="color: var(--muted);">
                  <th class="text-left py-2 px-3 border-b" style="border-color: var(--border);">Value</th>
                  <th class="text-left py-2 px-3 border-b" style="border-color: var(--border);">Frequency</th>
                  <th class="text-left py-2 px-3 border-b" style="border-color: var(--border);">Percentage</th>
                </tr>
              </thead>
              <tbody id="frequency-body" style="color: var(--fg);">
                <!-- Frequency rows will be rendered here -->
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    const state = {
      datasets: [],
      currentColor: '#00d4aa',
      dotSize: 10,
      dotOpacity: 0.8,
      showGrid: true,
      stackDuplicates: true,
      showTooltips: true
    };

    const colorPalette = [
      '#00d4aa', '#ff6b9d', '#ffd93d', '#6bcb77',
      '#4d96ff', '#9b59b6', '#e17055', '#00b894'
    ];

    const canvas = document.getElementById('dot-plot-canvas');
    if (canvas) {
      const ctx = canvas.getContext('2d');
      const tooltip = document.getElementById('tooltip');

      function init() {
        resizeCanvas();
        window.addEventListener('resize', resizeCanvas);
        addDataset();
        canvas.addEventListener('mousemove', handleMouseMove);
        canvas.addEventListener('mouseleave', () => { tooltip.classList.remove('visible'); });

        document.getElementById('data-input').addEventListener('input', debounce(updatePlot, 300));
        document.getElementById('label-input').addEventListener('input', debounce(updatePlot, 300));
        document.getElementById('dot-size').addEventListener('input', function() {
          document.getElementById('dot-size-value').textContent = this.value;
          updatePlot();
        });
        document.getElementById('dot-opacity').addEventListener('input', function() {
          document.getElementById('dot-opacity-value').textContent = this.value;
          updatePlot();
        });
        document.getElementById('color-picker').addEventListener('input', function() {
          document.getElementById('color-hex').textContent = this.value;
          updatePlot();
        });
      }

      function resizeCanvas() {
        const container = canvas.parentElement;
        const dpr = window.devicePixelRatio || 1;
        const rect = container.getBoundingClientRect();
        
        canvas.width = rect.width * dpr;
        canvas.height = Math.max(480, rect.height) * dpr;
        canvas.style.width = rect.width + 'px';
        canvas.style.height = Math.max(480, rect.height) + 'px';
        
        ctx.scale(dpr, dpr);
        updatePlot();
      }

      window.switchDotplotTab = function(tab) {
        document.querySelectorAll('.tab-btn').forEach(btn => {
          btn.classList.toggle('active', btn.dataset.tab === tab);
        });
        document.getElementById('manual-tab').classList.toggle('hidden', tab !== 'manual');
        document.getElementById('paste-tab').classList.toggle('hidden', tab !== 'paste');
      };

      function parseData(input) {
        return input.split(/[,\s]+/).map(v => parseFloat(v.trim())).filter(v => !isNaN(v));
      }

      window.addDataset = function() {
        const dataInput = document.getElementById('data-input');
        const labelInput = document.getElementById('label-input');
        const data = parseData(dataInput.value);
        if (data.length === 0) return;
        
        state.datasets.push({
          id: Date.now(),
          label: labelInput.value || `Dataset ${state.datasets.length + 1}`,
          data: data,
          color: colorPalette[state.datasets.length % colorPalette.length]
        });
        renderDatasetsList();
        updatePlot();
        updateColorPicker();
      };

      window.removeDataset = function(id) {
        state.datasets = state.datasets.filter(d => d.id !== id);
        renderDatasetsList();
        updatePlot();
        updateColorPicker();
      };

      function updateColorPicker() {
        if (state.datasets.length > 0) {
          const lastDataset = state.datasets[state.datasets.length - 1];
          document.getElementById('color-picker').value = lastDataset.color;
          document.getElementById('color-hex').textContent = lastDataset.color;
        }
      }

      function renderDatasetsList() {
        const container = document.getElementById('datasets-list');
        if (state.datasets.length === 0) {
          container.innerHTML = '<p class="text-sm" style="color: var(--muted);">No datasets added yet.</p>';
          return;
        }
        container.innerHTML = state.datasets.map(dataset => `
          <div class="flex items-center justify-between p-3 rounded-lg" style="background: var(--bg);">
            <div class="flex items-center gap-3">
              <div class="w-4 h-4 rounded-full" style="background: ${dataset.color};"></div>
              <div>
                <div class="font-medium text-sm" style="color: var(--fg);">${dataset.label}</div>
                <div class="text-xs" style="color: var(--muted);">${dataset.data.length} points</div>
              </div>
            </div>
            <div class="flex items-center gap-2">
              <span class="data-badge">${calcMean(dataset.data).toFixed(1)} mean</span>
              <button onclick="removeDataset(${dataset.id})" class="p-1 rounded hover:bg-red-500/20 transition-colors" style="color: var(--danger);" aria-label="Remove dataset">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
              </button>
            </div>
          </div>
        `).join('');
      }

      window.parsePasteData = function() {
        const input = document.getElementById('paste-input').value;
        input.split('\n').filter(l => l.trim()).forEach((line, i) => {
          const data = parseData(line);
          if (data.length > 0) {
            state.datasets.push({ id: Date.now() + i, label: `Imported ${i+1}`, data: data, color: colorPalette[state.datasets.length % colorPalette.length] });
          }
        });
        renderDatasetsList();
        updatePlot();
        updateColorPicker();
        switchDotplotTab('manual');
      };

      window.toggleAdvancedGrid = function() {
        state.showGrid = !state.showGrid;
        const toggle = document.getElementById('grid-toggle');
        const knob = toggle.querySelector('div');
        toggle.style.background = state.showGrid ? 'var(--accent)' : 'var(--border)';
        knob.style.transform = state.showGrid ? 'translateX(1.5rem)' : 'translateX(0)';
        updatePlot();
      };

      window.toggleAdvancedStack = function() {
        state.stackDuplicates = !state.stackDuplicates;
        const toggle = document.getElementById('stack-toggle');
        const knob = toggle.querySelector('div');
        toggle.style.background = state.stackDuplicates ? 'var(--accent)' : 'var(--border)';
        knob.style.transform = state.stackDuplicates ? 'translateX(1.5rem)' : 'translateX(0)';
        updatePlot();
      };

      function drawGrid(width, height, padding, minVal, maxVal) {
        if (!state.showGrid) return;
        ctx.strokeStyle = 'rgba(107, 125, 143, 0.15)';
        ctx.lineWidth = 1;
        for (let i = 0; i <= 8; i++) {
          const y = padding.top + (height - padding.top - padding.bottom) * (i / 8);
          ctx.beginPath(); ctx.moveTo(padding.left, y); ctx.lineTo(width - padding.right, y); ctx.stroke();
        }
        for (let i = 0; i <= 10; i++) {
          const x = padding.left + (width - padding.left - padding.right) * (i / 10);
          ctx.beginPath(); ctx.moveTo(x, padding.top); ctx.lineTo(x, height - padding.bottom); ctx.stroke();
        }
      }

      function drawAxes(width, height, padding, minVal, maxVal) {
        ctx.strokeStyle = 'rgba(107, 125, 143, 0.5)';
        ctx.lineWidth = 2;
        ctx.font = '12px "IBM Plex Mono", monospace';
        ctx.fillStyle = '#6b7d8f';
        ctx.beginPath(); ctx.moveTo(padding.left, height - padding.bottom); ctx.lineTo(width - padding.right, height - padding.bottom); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(padding.left, padding.top); ctx.lineTo(padding.left, height - padding.bottom); ctx.stroke();
        
        const range = maxVal - minVal;
        for (let i = 0; i <= 5; i++) {
          const val = minVal + (range / 5) * i;
          const x = padding.left + (width - padding.left - padding.right) * (i / 5);
          ctx.textAlign = 'center';
          ctx.fillText(val.toFixed(1), x, height - padding.bottom + 20);
        }
      }

      window.updatePlot = function() {
        const dpr = window.devicePixelRatio || 1;
        const width = canvas.width / dpr, height = canvas.height / dpr;
        ctx.fillStyle = '#111920';
        ctx.fillRect(0, 0, width, height);
        
        const currentData = parseData(document.getElementById('data-input').value);
        const activeDatasets = state.datasets.length > 0 ? state.datasets : [{
          id: 0, label: document.getElementById('label-input').value || 'Sample Data',
          data: currentData.length > 0 ? currentData : [12, 15, 18, 12, 14, 16, 18, 20, 15, 13], color: document.getElementById('color-picker').value
        }];
        
        const allData = activeDatasets.flatMap(d => d.data);
        if (allData.length === 0) return;
        
        const minVal = Math.floor(Math.min(...allData)) - 1;
        const maxVal = Math.ceil(Math.max(...allData)) + 1;
        const padding = { top: 60, right: 40, bottom: 60, left: 60 };
        
        drawGrid(width, height, padding, minVal, maxVal);
        drawAxes(width, height, padding, minVal, maxVal);
        state.dotPositions = [];
        
        const dotSize = parseInt(document.getElementById('dot-size').value);
        const opacity = parseFloat(document.getElementById('dot-opacity').value);
        
        activeDatasets.forEach(dataset => {
          const stackCount = {};
          dataset.data.forEach(val => {
            const x = padding.left + ((val - minVal) / (maxVal - minVal)) * (width - padding.left - padding.right);
            let y;
            if (state.stackDuplicates) {
              stackCount[val] = (stackCount[val] || 0);
              y = height - padding.bottom - dotSize - (stackCount[val] * dotSize * 2);
              stackCount[val]++;
            } else {
              y = height - padding.bottom - dotSize;
            }
            
            const gradient = ctx.createRadialGradient(x, y, 0, x, y, dotSize);
            gradient.addColorStop(0, adjustColorOpacity(dataset.color, opacity));
            gradient.addColorStop(0.7, adjustColorOpacity(dataset.color, opacity * 0.8));
            gradient.addColorStop(1, adjustColorOpacity(dataset.color, opacity * 0.3));
            
            ctx.beginPath(); ctx.arc(x, y, dotSize, 0, Math.PI * 2);
            ctx.fillStyle = gradient; ctx.fill();
            ctx.strokeStyle = adjustColorOpacity(dataset.color, opacity * 0.5); ctx.lineWidth = 1; ctx.stroke();
            
            state.dotPositions.push({ x, y, value: val, dataset: dataset.label, color: dataset.color });
          });
        });
        
        ctx.font = 'bold 16px "Space Grotesk", sans-serif';
        ctx.fillStyle = '#e8eef4';
        ctx.textAlign = 'center';
        ctx.fillText(activeDatasets.length === 1 ? activeDatasets[0].label : 'Dot Plot Visualization', width / 2, 30);
        
        updateStatistics(allData);
        updateFrequencyTable(allData);
      };

      function adjustColorOpacity(hex, opacity) {
        const r = parseInt(hex.slice(1, 3), 16), g = parseInt(hex.slice(3, 5), 16), b = parseInt(hex.slice(5, 7), 16);
        return `rgba(${r}, ${g}, ${b}, ${opacity})`;
      }

      function calcMean(data) { return data.reduce((a, b) => a + b, 0) / data.length; }
      function calcMedian(data) {
        const sorted = [...data].sort((a, b) => a - b);
        const mid = Math.floor(sorted.length / 2);
        return sorted.length % 2 ? sorted[mid] : (sorted[mid - 1] + sorted[mid]) / 2;
      }
      function calcStdDev(data) {
        const mean = calcMean(data);
        return Math.sqrt(data.map(val => Math.pow(val - mean, 2)).reduce((a, b) => a + b, 0) / data.length);
      }

      function updateStatistics(data) {
        document.getElementById('stat-count').textContent = data.length;
        document.getElementById('stat-mean').textContent = calcMean(data).toFixed(2);
        document.getElementById('stat-median').textContent = calcMedian(data).toFixed(2);
        document.getElementById('stat-std').textContent = calcStdDev(data).toFixed(2);
      }

      function updateFrequencyTable(data) {
        const frequency = {};
        data.forEach(val => { frequency[val] = (frequency[val] || 0) + 1; });
        const sorted = Object.entries(frequency).sort((a, b) => parseFloat(a[0]) - parseFloat(b[0]));
        document.getElementById('frequency-body').innerHTML = sorted.slice(0, 10).map(([val, count]) => `
          <tr>
            <td class="py-2 px-3 font-mono" style="color: var(--accent);">${val}</td>
            <td class="py-2 px-3 font-mono">${count}</td>
            <td class="py-2 px-3">
              <div class="flex items-center gap-2">
                <div class="h-2 rounded" style="width: ${(count/data.length) * 100}px; background: var(--accent); opacity: 0.6;"></div>
                <span class="font-mono text-xs">${((count/data.length) * 100).toFixed(1)}%</span>
              </div>
            </td>
          </tr>
        `).join('') + (sorted.length > 10 ? `<tr><td colspan="3" class="py-2 px-3 text-center" style="color: var(--muted);">... and ${sorted.length - 10} more values</td></tr>` : '');
      }

      function handleMouseMove(e) {
        const rect = canvas.getBoundingClientRect(), x = e.clientX - rect.left, y = e.clientY - rect.top;
        const dotSize = parseInt(document.getElementById('dot-size').value);
        let found = state.dotPositions.find(dot => Math.sqrt(Math.pow(x - dot.x, 2) + Math.pow(y - dot.y, 2)) < dotSize + 5);
        if (found) {
          tooltip.innerHTML = `<span style="color: ${found.color};">●</span> Value: <strong>${found.value}</strong>`;
          tooltip.style.left = (found.x + dotSize + 10) + 'px';
          tooltip.style.top = (found.y - 10) + 'px';
          tooltip.classList.add('visible');
        } else {
          tooltip.classList.remove('visible');
        }
      }

      window.exportSVG = function() {
        const dpr = window.devicePixelRatio || 1, w = canvas.width / dpr, h = canvas.height / dpr;
        const dotSize = parseInt(document.getElementById('dot-size').value), opacity = parseFloat(document.getElementById('dot-opacity').value);
        const dots = state.dotPositions.map(dot => `<circle cx="${dot.x}" cy="${dot.y}" r="${dotSize}" fill="${adjustColorOpacity(dot.color, opacity)}" stroke="${adjustColorOpacity(dot.color, opacity * 0.5)}"/>`).join('');
        downloadFile(`<?xml version="1.0" encoding="UTF-8"?>\n<svg xmlns="http://www.w3.org/2000/svg" width="${w}" height="${h}" viewBox="0 0 ${w} ${h}">\n<rect width="${w}" height="${h}" fill="#111920"/>\n${dots}\n</svg>`, 'dot-plot.svg', 'image/svg+xml');
      };

      window.exportPNG = function() {
        const link = document.createElement('a'); link.download = 'dot-plot.png'; link.href = canvas.toDataURL('image/png'); link.click();
      };

      function downloadFile(content, filename, type) {
        const blob = new Blob([content], { type }), url = URL.createObjectURL(blob), link = document.createElement('a');
        link.href = url; link.download = filename; link.click(); URL.revokeObjectURL(url);
      }

      function debounce(func, wait) {
        let timeout;
        return function(...args) { clearTimeout(timeout); timeout = setTimeout(() => func(...args), wait); };
      }

      // Initialize delay to ensure styles loaded
      setTimeout(init, 100);
    }
  </script>
</section>
