---
import Header from "@theme/components/Header.astro";
import Footer from "@theme/components/Footer.astro";
import "@src/styles/global.css";
import { defaultLocale, isRtl, ogLocaleMap, type Locale } from "@src/i18n/config";
import { t } from "@src/i18n/utils";
import siteConfig from "@src/config/site.json";

interface Props {
  title?: string;
  description?: string;
  locale?: Locale;
  canonicalUrl?: string;
  ogType?: string;
  pageType?: "about" | "contact" | null;
}

const {
  locale = defaultLocale,
  canonicalUrl = Astro.url.href,
  ogType = "website",
  pageType = null,
} = Astro.props;

const title = Astro.props.title || t(locale, "site.title");
const description = Astro.props.description || t(locale, "site.description");

const dir = isRtl(locale) ? "rtl" : "ltr";
const ogLocale = ogLocaleMap[locale] || "en_US";
const fullTitle = title.includes(siteConfig.siteName) ? title : `${title} | ${siteConfig.siteName}`;
const siteOrigin = new URL(siteConfig.siteUrl).origin;

function normalizeCanonicalUrl(urlValue: string): string {
  const parsed = new URL(urlValue, siteConfig.siteUrl);
  const pathname = parsed.pathname.endsWith("/") ? parsed.pathname : `${parsed.pathname}/`;
  return `${siteOrigin}${pathname}`;
}

const resolvedCanonicalUrl = normalizeCanonicalUrl(canonicalUrl);
---

<!doctype html>
<html lang={locale} dir={dir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Title & Description -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />

    <!-- Canonical -->
    <link rel="canonical" href={resolvedCanonicalUrl} />

    <!-- Robots -->
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="googlebot" content="index, follow" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Verification Meta (conditional) -->
    {siteConfig.verification.google && (
      <meta name="google-site-verification" content={siteConfig.verification.google} />
    )}
    {siteConfig.verification.bing && (
      <meta name="msvalidate.01" content={siteConfig.verification.bing} />
    )}
    {siteConfig.verification.yandex && (
      <meta name="yandex-verification" content={siteConfig.verification.yandex} />
    )}

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={resolvedCanonicalUrl} />
    <meta property="og:site_name" content={siteConfig.siteName} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:image" content={`${siteConfig.siteUrl}${siteConfig.metaImage}`} />
    <meta property="og:image:width" content={String(siteConfig.metaImageWidth)} />
    <meta property="og:image:height" content={String(siteConfig.metaImageHeight)} />
    <meta property="og:image:alt" content={siteConfig.metaImageAlt} />
    <meta property="og:type" content={ogType} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteConfig.siteUrl}${siteConfig.metaImage}`} />

    <!-- Organization Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      name: siteConfig.siteName,
      url: siteConfig.siteUrl,
      legalName: siteConfig.legalName,
      logo: {
        "@type": "ImageObject",
        url: `${siteConfig.siteUrl}/favicon.svg`,
      },
      description: t("en", "site.description"),
      sameAs: Object.values(siteConfig.social).filter(Boolean),
    })} />

    <!-- SiteNavigationElement Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": siteConfig.headerNav.map((item: any) => ({
        "@type": "SiteNavigationElement",
        name: t(locale, item.label),
        url: `${siteConfig.siteUrl}${item.href}`,
      })),
    })} />

    <!-- Conditional Page Schemas -->
    {pageType === "about" && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "AboutPage",
        name: t(locale, "about.title"),
        url: resolvedCanonicalUrl,
        description: t(locale, "about.intro"),
      })} />
    )}
    {pageType === "contact" && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "ContactPage",
        name: t(locale, "contact.title"),
        url: resolvedCanonicalUrl,
        description: t(locale, "contact.intro"),
      })} />
    )}

    <slot name="head" />
  </head>
  <body>
    <div class="dot-bg" aria-hidden="true"></div>
    <div class="glow glow-teal" style="top: -200px; left: -100px;" aria-hidden="true"></div>
    <div class="glow glow-purple" style="top: 200px; right: -150px;" aria-hidden="true"></div>

    <Header locale={locale} />

    <main class="container" style="position: relative; z-index: 1; min-height: 60vh;">
      <slot />
    </main>

    <Footer locale={locale} />
  </body>
</html>
